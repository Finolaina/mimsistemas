---
/**
 * Hero.astro — Full-height hero with background image + lead-gen form
 * Design System: "The Digital Monolith"
 *
 * - hero-gradient overlay from global.css
 * - Asymmetrical layout: text left, form right
 * - Ambient shadows on form card
 * - Trust badges with filled check_circle icons
 * - GEO-optimized paragraph (first 200 words answer the key query)
 */
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero-building.png';
---

<section
  class="relative min-h-screen pt-20 flex items-center overflow-hidden"
  id="inicio"
  aria-label="Presentación principal de MIM Sistemas"
>
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImg}
      alt="Fachada de edificio residencial moderno al atardecer en Madrid"
      class="w-full h-full object-cover"
      widths={[640, 1024, 1536, 2048]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 hero-gradient"></div>
  </div>

  <!-- Content grid -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12 lg:gap-16 items-center w-full py-20 lg:py-28">

    <!-- Hero Left — 7 columns for asymmetry -->
    <div class="lg:col-span-7 text-white space-y-8">

      <!-- Badge -->
      <div
        class="hero-animate hero-animate-d1 inline-flex items-center px-4 py-1.5 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-sm font-medium"
      >
        <span class="w-2 h-2 rounded-full bg-tertiary-fixed mr-2.5" aria-hidden="true"></span>
        Profesionales homologados &middot; Desde 2003
      </div>

      <!-- H1 -->
      <h1 class="hero-animate hero-animate-d2 text-5xl lg:text-7xl font-bold tracking-tighter leading-[1.08]">
        Soluciones Integrales para tu
        <span class="text-tertiary-fixed">Comunidad</span> y Empresa
      </h1>

      <!-- GEO-optimized paragraph -->
      <p class="hero-animate hero-animate-d3 text-xl text-blue-100 max-w-xl leading-relaxed">
        Instalación, reparación y mantenimiento multitécnico con la garantía de
        más de 20 años de experiencia en el sector. MIM Sistemas es la empresa
        líder en servicios técnicos integrales para comunidades de propietarios
        y empresas en Madrid.
      </p>

      <!-- CTA buttons -->
      <div class="hero-animate hero-animate-d4 flex flex-col sm:flex-row gap-4">
        <a
          href="#contacto"
          class="inline-flex items-center justify-center bg-tertiary-fixed text-on-tertiary-fixed px-8 py-4 rounded-xl font-bold text-lg hover:brightness-110 transition-all shadow-lg shadow-black/20"
        >
          Solicitar Presupuesto Gratis
        </a>
        <a
          href="tel:912000002"
          class="inline-flex items-center justify-center gap-2 border-2 border-white/30 px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 transition-all backdrop-blur-sm"
        >
          <span class="material-symbols-outlined" aria-hidden="true">call</span>
          912 000 002
        </a>
      </div>

      <!-- Trust badges -->
      <div class="hero-animate hero-animate-d5 grid grid-cols-2 gap-x-6 gap-y-3 pt-4">
        <div class="flex items-center gap-2 text-sm">
          <span
            class="material-symbols-outlined text-tertiary-fixed text-lg"
            style="font-variation-settings: 'FILL' 1;"
            aria-hidden="true"
          >check_circle</span>
          Técnicos Propios
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span
            class="material-symbols-outlined text-tertiary-fixed text-lg"
            style="font-variation-settings: 'FILL' 1;"
            aria-hidden="true"
          >check_circle</span>
          Atención Urgente 24h
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span
            class="material-symbols-outlined text-tertiary-fixed text-lg"
            style="font-variation-settings: 'FILL' 1;"
            aria-hidden="true"
          >check_circle</span>
          Presupuesto Cerrado
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span
            class="material-symbols-outlined text-tertiary-fixed text-lg"
            style="font-variation-settings: 'FILL' 1;"
            aria-hidden="true"
          >check_circle</span>
          Garantía por Escrito
        </div>
      </div>
    </div>

    <!-- Hero Right — 5 columns, contact form -->
    <div class="hero-animate hero-animate-d3 lg:col-span-5 lg:justify-self-end w-full max-w-md" id="contacto">
      <div class="bg-white rounded-2xl p-8 ambient-shadow">

        <h2 class="text-2xl font-bold text-primary mb-2">Te llamamos gratis</h2>
        <p class="text-on-surface-variant text-sm mb-6 font-medium leading-relaxed">
          Déjanos tus datos y un técnico te contactará en menos de 1 hora.
        </p>

        <form class="space-y-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
          <input type="hidden" name="origen" value="hero-v1" />
          <!-- Honeypot anti-spam -->
          <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
            <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Nombre -->
          <div>
            <label
              for="hero-nombre"
              class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1 ml-1"
            >Nombre</label>
            <input
              id="hero-nombre"
              name="nombre"
              type="text"
              autocomplete="name"
              required
              placeholder="Ej: Juan García"
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-on-surface placeholder:text-outline focus:ring-2 focus:ring-secondary focus:bg-white transition-all"
            />
          </div>

          <!-- Teléfono + Email -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label
                for="hero-telefono"
                class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1 ml-1"
              >Teléfono</label>
              <input
                id="hero-telefono"
                name="telefono"
                type="tel"
                autocomplete="tel"
                required
                placeholder="600 000 000"
                class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-on-surface placeholder:text-outline focus:ring-2 focus:ring-secondary focus:bg-white transition-all"
              />
            </div>
            <div>
              <label
                for="hero-email"
                class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1 ml-1"
              >Email</label>
              <input
                id="hero-email"
                name="email"
                type="email"
                autocomplete="email"
                placeholder="email@ejemplo.com"
                class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-on-surface placeholder:text-outline focus:ring-2 focus:ring-secondary focus:bg-white transition-all"
              />
            </div>
          </div>

          <!-- Servicio (select) -->
          <div>
            <label
              for="hero-servicio"
              class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1 ml-1"
            >¿Qué necesitas?</label>
            <select
              id="hero-servicio"
              name="servicio"
              required
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-on-surface focus:ring-2 focus:ring-secondary focus:bg-white transition-all"
            >
              <option value="">Selecciona un servicio</option>
              <option value="seguridad">Seguridad / Accesos</option>
              <option value="automatismos">Automatismos</option>
              <option value="energia-solar">Energía Solar</option>
              <option value="electricidad">Electricidad</option>
              <option value="otros">Otros Servicios</option>
            </select>
          </div>

          <!-- Mensaje -->
          <div>
            <label
              for="hero-mensaje"
              class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1 ml-1"
            >Mensaje <span class="normal-case tracking-normal font-normal">(opcional)</span></label>
            <textarea
              id="hero-mensaje"
              name="mensaje"
              rows="2"
              placeholder="Describe brevemente lo que necesitas..."
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-on-surface placeholder:text-outline focus:ring-2 focus:ring-secondary focus:bg-white transition-all resize-none"
            ></textarea>
          </div>

          <!-- RGPD consent -->
          <label class="flex items-start gap-2.5 cursor-pointer">
            <input type="checkbox" name="rgpd" required
              class="mt-0.5 w-4 h-4 rounded border-outline text-secondary focus:ring-secondary/30 cursor-pointer" />
            <span class="text-xs text-on-surface-variant leading-relaxed">
              Acepto la <a href="/mimsistemas/politica-privacidad" target="_blank" class="text-secondary underline hover:text-secondary/80">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
            </span>
          </label>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-tertiary-fixed text-on-tertiary-fixed font-bold py-4 rounded-xl hover:brightness-105 active:scale-[0.98] transition-all shadow-md cursor-pointer"
          >
            <span class="btn-text">Enviar Solicitud</span>
          </button>

          <!-- Success/error messages -->
          <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
            <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
            <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
          </div>
          <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
            <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
            <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
          </div>
        </form>
      </div>
    </div>

  </div>
</section>
