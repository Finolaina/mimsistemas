---
/**
 * WhyUs.astro
 * "The Digital Monolith" — 4 reasons to choose MIM Sistemas
 * bg-surface shifts from surface-container-low above
 */

const reasons = [
  {
    icon: "history",
    title: "Experiencia",
    description:
      "Mas de dos decadas liderando el sector de servicios tecnicos integrales.",
  },
  {
    icon: "hub",
    title: "Proveedor Unico",
    description:
      "Centralizamos todas las necesidades tecnicas bajo una sola gestion profesional.",
  },
  {
    icon: "verified_user",
    title: "Homologacion",
    description:
      "Empresa registrada y habilitada para todas nuestras especialidades.",
  },
  {
    icon: "bolt",
    title: "Rapidez",
    description:
      "Respuesta inmediata para avisos urgentes y plazos de ejecucion cortos.",
  },
];
---

<section id="nosotros" class="py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-center text-primary mb-16" data-animate>
      &iquest;Por que elegir MIM SISTEMAS?
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12" data-animate data-delay="1">
      {
        reasons.map((reason) => (
          <div class="text-center">
            <div class="w-16 h-16 bg-surface-container-low rounded-2xl flex items-center justify-center mx-auto mb-6">
              <span
                class="material-symbols-outlined text-secondary text-3xl"
                aria-hidden="true"
              >
                {reason.icon}
              </span>
            </div>
            <h3 class="text-xl font-bold mb-3">{reason.title}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              {reason.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
