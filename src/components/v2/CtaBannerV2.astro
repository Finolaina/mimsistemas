---
/**
 * CtaBannerV2.astro — Amber CTA banner with call + WhatsApp buttons
 */
---
<!-- CTA Banner: Amber gradient with animated shapes & shimmer -->
<section class="relative py-20 md:py-24 bg-gradient-to-br from-cta via-[#FBBF24] to-cta-hover overflow-hidden" aria-label="Contacto directo">
  <!-- Decorative animated circles -->
  <div class="absolute top-0 right-0 w-80 h-80 bg-white/10 rounded-full -translate-y-1/3 translate-x-1/3 v2-float-1" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-56 h-56 bg-white/10 rounded-full translate-y-1/3 -translate-x-1/3 v2-float-2" aria-hidden="true"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-white/10 rounded-full v2-float-3" aria-hidden="true"></div>

  <!-- Dot pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, rgba(15,23,42,0.15) 1px, transparent 1px); background-size: 20px 20px;" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center v2-reveal">
    <div class="inline-flex items-center gap-2 bg-primary/10 rounded-full px-5 py-2 mb-6">
      <span class="material-symbols-outlined text-primary text-lg" aria-hidden="true">handshake</span>
      <span class="text-sm font-heading font-semibold text-primary/80">Sin compromiso</span>
    </div>

    <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mb-4">
      ¿Necesitas un Presupuesto Cerrado?
    </h2>
    <p class="text-primary/60 text-lg mb-10 max-w-xl mx-auto">
      Contáctanos sin compromiso. Respondemos en menos de 1 hora.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="tel:912000002" class="v2-btn-outline !border-primary/80 !text-primary hover:!bg-primary hover:!text-white text-lg w-full sm:w-auto justify-center !py-4 !px-8">
        <span class="material-symbols-outlined text-2xl" aria-hidden="true">call</span>
        912 000 002
      </a>
      <a href="https://wa.me/34912000002?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto." target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] text-white font-heading font-semibold px-8 py-4 rounded-xl text-lg hover:bg-[#1da851] transition-all cursor-pointer w-full sm:w-auto justify-center shadow-lg hover:shadow-xl hover:-translate-y-0.5">
        <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Enviar WhatsApp
      </a>
    </div>
  </div>
</section>
