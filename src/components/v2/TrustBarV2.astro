<!-- Trust Stats: Animated gradient bg + glowing numbers -->
<section class="relative v2-trust-bar py-0" aria-label="Datos destacados">
  <!-- Dot pattern overlay -->
  <div class="absolute inset-0 v2-dot-pattern-light opacity-20" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
      <div class="py-10 md:py-12 px-4 md:px-8 text-center group">
        <div class="v2-counter v2-stat-glow text-4xl md:text-5xl font-bold text-cta" data-target="20" data-suffix="+">0</div>
        <div class="text-sm text-white/60 mt-2 font-medium tracking-wide">Años de experiencia</div>
      </div>
      <div class="py-10 md:py-12 px-4 md:px-8 text-center group">
        <div class="v2-counter text-4xl md:text-5xl font-bold text-white" data-target="2000" data-prefix="+" data-suffix="">0</div>
        <div class="text-sm text-white/60 mt-2 font-medium tracking-wide">Comunidades</div>
      </div>
      <div class="py-10 md:py-12 px-4 md:px-8 text-center group">
        <div class="v2-counter text-4xl md:text-5xl font-bold text-white" data-target="100" data-suffix="%">0</div>
        <div class="text-sm text-white/60 mt-2 font-medium tracking-wide">Homologados</div>
      </div>
      <div class="py-10 md:py-12 px-4 md:px-8 text-center group">
        <div class="text-4xl md:text-5xl font-heading font-bold v2-stat-glow text-cta">24h</div>
        <div class="text-sm text-white/60 mt-2 font-medium tracking-wide">Servicio Urgente</div>
      </div>
    </div>
  </div>
</section>
