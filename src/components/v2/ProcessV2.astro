---
const steps = [
  { num: "01", title: "Contacto", desc: "Llámanos o escríbenos. Analizamos tu necesidad de inmediato.", icon: "call" },
  { num: "02", title: "Visita y Presupuesto", desc: "Un técnico visita la comunidad y emite un presupuesto sin compromiso.", icon: "assignment" },
  { num: "03", title: "Ejecución", desc: "Realizamos el trabajo con materiales de primera calidad y orden.", icon: "construction" },
  { num: "04", title: "Garantía", desc: "Entrega de certificados y seguimiento post-venta asegurado.", icon: "verified" },
];
---
<!-- Process: Enhanced timeline with dashed animated connections & glow dots -->
<section class="relative py-20 md:py-28 bg-white overflow-hidden">
  <!-- Dot pattern bg -->
  <div class="absolute inset-0 v2-dot-pattern opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16 v2-reveal">
      <span class="v2-section-label">Cómo Trabajamos</span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3">
        Nuestro Proceso en
        <span class="v2-gradient-text">4 Pasos</span>
      </h2>
    </div>

    <!-- Desktop: Horizontal Timeline -->
    <div class="hidden md:block v2-reveal">
      <div class="relative">
        <!-- Animated dashed SVG line -->
        <svg class="absolute top-7 left-[12%] right-[12%] h-2 w-[76%]" viewBox="0 0 800 2" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line x1="0" y1="1" x2="800" y2="1" stroke="url(#timeline-gradient)" stroke-width="2" class="v2-dashed-line"/>
          <defs>
            <linearGradient id="timeline-gradient" x1="0" y1="0" x2="800" y2="0">
              <stop offset="0%" stop-color="#0369A1"/>
              <stop offset="50%" stop-color="#F59E0B"/>
              <stop offset="100%" stop-color="#0EA5E9"/>
            </linearGradient>
          </defs>
        </svg>

        <div class="grid grid-cols-4 gap-6">
          {steps.map((step, i) => (
            <div class="flex flex-col items-center text-center group cursor-default">
              <!-- Dot with pulse ring -->
              <div class="relative mb-8">
                <div class="v2-timeline-dot group-hover:scale-110 transition-transform duration-300">
                  <span class="material-symbols-outlined text-xl text-white" aria-hidden="true">{step.icon}</span>
                </div>
                <!-- Pulse ring on hover -->
                <div class="absolute inset-0 rounded-full border-2 border-accent opacity-0 group-hover:animate-ping pointer-events-none" aria-hidden="true"></div>
              </div>
              <div class="bg-white rounded-2xl p-5 shadow-sm border border-border group-hover:shadow-lg group-hover:border-accent/20 transition-all duration-300">
                <div class="text-xs font-heading font-bold text-accent/50 mb-1">PASO {step.num}</div>
                <h3 class="font-heading font-semibold text-primary text-lg mb-2 group-hover:text-accent transition-colors">{step.title}</h3>
                <p class="text-text-muted text-sm leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Mobile: Vertical Timeline -->
    <div class="md:hidden flex flex-col gap-0 v2-stagger">
      {steps.map((step, i) => (
        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="v2-timeline-dot flex-shrink-0">
              <span class="material-symbols-outlined text-lg text-white" aria-hidden="true">{step.icon}</span>
            </div>
            {i < 3 && (
              <div class="w-0.5 flex-1 mt-2 bg-gradient-to-b from-accent/30 to-accent/10"></div>
            )}
          </div>
          <div class="pb-8">
            <div class="text-xs font-heading font-bold text-accent/50 mb-0.5">PASO {step.num}</div>
            <h3 class="font-heading font-semibold text-primary text-lg mb-1">{step.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
