---
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-icon.png';
---
<!-- Back to top button -->
<button
  id="v2-back-to-top"
  class="fixed bottom-[140px] right-6 z-40 md:bottom-[88px] md:right-8 w-11 h-11 bg-primary/80 backdrop-blur-sm text-white rounded-full shadow-lg hover:bg-accent hover:shadow-xl transition-all duration-300 flex items-center justify-center opacity-0 translate-y-4 pointer-events-none"
  aria-label="Volver arriba"
>
  <span class="material-symbols-outlined text-xl" aria-hidden="true">keyboard_arrow_up</span>
</button>

<script>
  const backToTop = document.getElementById('v2-back-to-top');
  if (backToTop) {
    const toggleVisibility = () => {
      if (window.scrollY > 400) {
        backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        backToTop.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      } else {
        backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        backToTop.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    };
    window.addEventListener('scroll', toggleVisibility, { passive: true });
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<!-- Floating WhatsApp Button with pulse ring -->
<aside class="fixed bottom-[70px] right-6 z-40 md:bottom-8 md:right-8" aria-label="Contactar por WhatsApp">
  <a href="https://wa.me/34912000002" target="_blank" rel="noopener noreferrer"
    class="relative flex items-center justify-center w-[60px] h-[60px] bg-[#25D366] rounded-full shadow-xl hover:shadow-2xl hover:scale-110 transition-all duration-300 cursor-pointer group"
    aria-label="Abrir chat de WhatsApp">
    <Image src={whatsappIcon} alt="" width={32} height={32} class="w-8 h-8 relative z-10 group-hover:scale-110 transition-transform" />
    <!-- Pulse rings -->
    <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-20 pointer-events-none" aria-hidden="true"></span>
    <span class="absolute -inset-1 rounded-full border-2 border-[#25D366]/30 pointer-events-none" aria-hidden="true"></span>
  </a>
</aside>

<!-- Mobile Call Bar with gradient -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-gradient-to-r from-primary via-primary-light to-primary backdrop-blur-sm border-t border-white/10 safe-area-inset-bottom">
  <a href="tel:912000002" class="flex items-center justify-center gap-2.5 py-3.5 text-white font-heading font-semibold text-sm cursor-pointer group">
    <span class="material-symbols-outlined text-lg text-cta group-hover:animate-bounce" aria-hidden="true">call</span>
    Llamar Ahora — 912 000 002
  </a>
</div>
