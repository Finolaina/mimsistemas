---
/**
 * FloatingV2.astro — WhatsApp button, back-to-top & mobile call bar
 * Uses inline SVG for reliable rendering across all browsers
 */
---
<!-- Back to top button -->
<button
  id="v2-back-to-top"
  class="fixed bottom-[152px] right-5 z-40 md:bottom-[96px] md:right-8 w-11 h-11 bg-primary/90 backdrop-blur-sm text-white rounded-full shadow-lg hover:bg-accent hover:shadow-xl transition-all duration-300 flex items-center justify-center opacity-0 translate-y-4 pointer-events-none"
  aria-label="Volver arriba"
>
  <span class="material-symbols-outlined text-xl" aria-hidden="true">keyboard_arrow_up</span>
</button>

<script>
  const backToTop = document.getElementById('v2-back-to-top');
  if (backToTop) {
    const toggleVisibility = () => {
      if (window.scrollY > 400) {
        backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        backToTop.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      } else {
        backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        backToTop.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    };
    window.addEventListener('scroll', toggleVisibility, { passive: true });
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<!-- Floating WhatsApp Button -->
<aside class="fixed bottom-[82px] right-5 z-40 md:bottom-8 md:right-8" aria-label="Contactar por WhatsApp">
  <a href="https://wa.me/34912000002?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto." target="_blank" rel="noopener noreferrer"
    class="v2-whatsapp-btn group relative flex items-center justify-center w-[60px] h-[60px] bg-[#25D366] rounded-full shadow-[0_4px_20px_rgba(37,211,102,0.4)] hover:shadow-[0_6px_30px_rgba(37,211,102,0.55)] hover:scale-110 transition-all duration-300 cursor-pointer"
    aria-label="Abrir chat de WhatsApp">
    <!-- WhatsApp SVG icon -->
    <svg class="w-[34px] h-[34px] relative z-10 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <!-- Pulse rings -->
    <span class="absolute inset-0 rounded-full bg-[#25D366]/40 animate-[pulse-ring_2s_cubic-bezier(0.4,0,0.6,1)_infinite] pointer-events-none" aria-hidden="true"></span>
    <span class="absolute inset-0 rounded-full bg-[#25D366]/20 animate-[pulse-ring_2s_cubic-bezier(0.4,0,0.6,1)_0.5s_infinite] pointer-events-none" aria-hidden="true"></span>
    <!-- Tooltip -->
    <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 bg-white text-primary text-sm font-heading font-semibold px-4 py-2 rounded-xl shadow-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none hidden md:block">
      Escríbenos por WhatsApp
    </span>
  </a>
</aside>

<!-- Mobile Call Bar -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-gradient-to-r from-primary via-primary-light to-primary border-t border-white/10 safe-area-inset-bottom">
  <div class="flex">
    <a href="tel:912000002" class="flex-1 flex items-center justify-center gap-2 py-3.5 text-white font-heading font-semibold text-sm cursor-pointer group border-r border-white/10">
      <span class="material-symbols-outlined text-lg text-cta group-hover:animate-bounce" aria-hidden="true">call</span>
      Llamar Ahora
    </a>
    <a href="https://wa.me/34912000002?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto." target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 px-5 py-3.5 text-white font-heading font-semibold text-sm cursor-pointer group bg-[#25D366]/20">
      <svg class="w-5 h-5 fill-[#25D366]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
  </div>
</div>
