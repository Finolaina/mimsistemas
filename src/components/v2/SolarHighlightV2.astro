---
import { Image } from 'astro:assets';
import solarImg from '../../assets/images/panel-solar-comunidad-madrid.png';
---
<!-- Solar Highlight: Full-bleed split with floating badge & decorative elements -->
<section class="relative py-20 md:py-28 bg-white overflow-hidden">
  <!-- Decorative blob -->
  <div class="v2-blob w-[500px] h-[500px] bg-cta/8 -top-[10%] -right-[10%]" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Image with floating elements -->
      <div class="v2-reveal-left relative">
        <div class="rounded-2xl overflow-hidden shadow-xl relative group">
          <Image
            src={solarImg}
            alt="Paneles solares de alta calidad instalados en el tejado de un edificio residencial moderno"
            class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            widths={[400, 640, 800]}
            sizes="(max-width: 1023px) 100vw, 50vw"
            loading="lazy"
          />
          <!-- Overlay gradient on hover -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>

        <!-- Floating badge with glow -->
        <div class="v2-float-badge absolute -bottom-5 -right-5 sm:bottom-6 sm:right-6 bg-gradient-to-br from-cta to-cta-hover text-primary rounded-2xl px-6 py-4 shadow-xl">
          <div class="font-heading font-bold text-3xl">70%</div>
          <div class="text-xs font-semibold opacity-80">de ahorro</div>
        </div>

        <!-- Small decorative badge -->
        <div class="hidden lg:flex absolute -top-3 -left-3 bg-white rounded-xl px-4 py-2.5 shadow-lg items-center gap-2 border border-border">
          <span class="material-symbols-outlined text-success" aria-hidden="true">eco</span>
          <span class="text-xs font-heading font-semibold text-primary">Energía Verde</span>
        </div>
      </div>

      <!-- Content -->
      <div class="v2-reveal-right">
        <span class="v2-section-label">Especialistas en Energía</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-[2.75rem] font-bold text-primary mt-3 mb-6 leading-tight">
          Instalación y Mantenimiento de
          <span class="v2-gradient-text-blue">Placas Solares</span>
        </h2>
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          Reducimos la factura eléctrica comunitaria hasta en un 70% mediante tecnología de autoconsumo fotovoltaico.
        </p>

        <ul class="flex flex-col gap-4 mb-8">
          {[
            "Estudio de viabilidad gratuito y personalizado.",
            "Tramitación íntegra de subvenciones y ayudas.",
            "Mantenimiento preventivo incluido durante el primer año."
          ].map(item => (
            <li class="flex items-start gap-3 group/item cursor-default">
              <div class="w-6 h-6 bg-success/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 group-hover/item:bg-success/20 transition-colors">
                <span class="material-symbols-outlined text-success text-sm" aria-hidden="true">check</span>
              </div>
              <span class="text-text group-hover/item:text-primary transition-colors">{item}</span>
            </li>
          ))}
        </ul>

        <a href="#contacto" class="v2-btn-cta text-base">
          <span class="material-symbols-outlined text-xl" aria-hidden="true">calculate</span>
          Calcular Ahorro Gratis
        </a>
      </div>
    </div>
  </div>
</section>
