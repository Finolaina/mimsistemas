---
/**
 * TrustBar.astro — Social proof stats bar with NumberTicker animation
 * Design System: "The Digital Monolith"
 * Animation: Magic UI NumberTicker (pure JS + IntersectionObserver)
 *
 * - bg-secondary, NO 1px borders — uses subtle opacity dividers
 * - Numbers: text-4xl font-black, animated count-up on scroll
 * - Labels: uppercase, tracking-widest, font-bold, opacity-80
 */

interface Stat {
  value: string;
  label: string;
  countTo: number;
  prefix?: string;
  suffix?: string;
  locale?: boolean;
}

const stats: Stat[] = [
  { value: '20+',    label: 'Años de experiencia', countTo: 20, suffix: '+' },
  { value: '+2.000', label: 'Comunidades',         countTo: 2000, prefix: '+', locale: true },
  { value: '100%',   label: 'Homologados',         countTo: 100, suffix: '%' },
  { value: '24h',    label: 'Servicio Urgente',     countTo: 24, suffix: 'h' },
];
---

<section
  class="bg-secondary py-12 text-white relative z-20"
  aria-label="Datos clave de MIM Sistemas"
>
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8">
    {stats.map((stat, i) => (
      <div
        class:list={[
          'text-center',
          i > 0 && 'md:border-l md:border-white/15',
          i === 2 && 'border-t md:border-t-0 border-white/15 pt-6 md:pt-0',
          i === 3 && 'border-t md:border-t-0 border-white/15 pt-6 md:pt-0',
        ]}
      >
        <div
          class="text-4xl font-black mb-1 text-white"
          aria-hidden="true"
          data-count-to={stat.countTo}
          data-count-prefix={stat.prefix || ''}
          data-count-suffix={stat.suffix || ''}
          {...(stat.locale ? { 'data-count-locale': '' } : {})}
        >
          {stat.value}
        </div>
        <div class="text-xs font-bold uppercase tracking-widest opacity-80">
          {stat.label}
        </div>
        <span class="sr-only">{stat.value} {stat.label}</span>
      </div>
    ))}
  </div>
</section>
