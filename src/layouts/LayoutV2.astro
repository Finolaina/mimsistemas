<body class="antialiased">
  <!-- Skip to content (accessibility) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none"
  >Saltar al contenido principal</a>
  <slot />

  <!-- Scroll Reveal Observer -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.v2-reveal, .v2-reveal-left, .v2-reveal-right, .v2-stagger').forEach(el => {
      observer.observe(el);
    });

    // Number counter animation
    document.querySelectorAll('.v2-counter[data-target]').forEach(counter => {
      const target = counter.getAttribute('data-target') || '';
      const prefix = counter.getAttribute('data-prefix') || '';
      const suffix = counter.getAttribute('data-suffix') || '';
      const numericTarget = parseInt(target.replace(/[^\d]/g, '')) || 0;

      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            let current = 0;
            const step = Math.max(1, Math.floor(numericTarget / 40));
            const timer = setInterval(() => {
              current += step;
              if (current >= numericTarget) {
                current = numericTarget;
                clearInterval(timer);
              }
              (entry.target as HTMLElement).textContent = prefix + current.toLocaleString('es-ES') + suffix;
            }, 30);
            counterObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      counterObserver.observe(counter);
    });

    // Mobile menu toggle
    const menuBtn = document.getElementById('v2-menu-btn');
    const mobileMenu = document.getElementById('v2-mobile-menu');
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
      const icon = menuBtn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = mobileMenu?.classList.contains('hidden') ? 'menu' : 'close';
      }
    });

    // Close mobile menu on link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
    });

    // OpnForm AJAX submission
    const OPNFORM_API = 'https://forms.optihost.pro/api';
    const OPNFORM_FIELD_MAP: Record<string, string> = {
      nombre: 'mim-nombre',
      telefono: 'mim-telefono',
      email: 'mim-email',
      servicio: 'mim-servicio',
      comunidad: 'mim-comunidad',
      mensaje: 'mim-mensaje',
      origen: 'mim-origen',
    };

    document.querySelectorAll('.opnform').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.target as HTMLFormElement;
        const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
        const btnText = btn.querySelector('.btn-text');
        const btnIcon = btn.querySelector('.btn-icon');
        const successEl = f.querySelector('.form-success') as HTMLElement;
        const errorEl = f.querySelector('.form-error') as HTMLElement;
        const slug = f.dataset.opnformSlug;

        // Honeypot check
        const honeypot = f.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (honeypot?.value) return;

        // Loading state
        btn.disabled = true;
        if (btnText) btnText.textContent = 'Enviando...';
        if (btnIcon) (btnIcon as HTMLElement).textContent = 'hourglass_empty';
        successEl?.classList.add('hidden');
        errorEl?.classList.add('hidden');

        // Build payload with OpnForm field UUIDs
        const fd = new FormData(f);
        const payload: Record<string, string> = {};
        for (const [name, value] of fd.entries()) {
          const fieldId = OPNFORM_FIELD_MAP[name];
          if (fieldId && typeof value === 'string' && value.trim()) {
            let v = value.trim();
            // Normalize Spanish phone numbers to E.164
            if (name === 'telefono') {
              const digits = v.replace(/[\s\-().]/g, '');
              if (/^[67]\d{8}$/.test(digits)) v = '+34' + digits;
              else if (/^34[67]\d{8}$/.test(digits)) v = '+' + digits;
            }
            payload[fieldId] = v;
          }
        }

        try {
          const res = await fetch(`${OPNFORM_API}/forms/${slug}/answer`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (res.ok && data.type === 'success') {
            successEl?.classList.remove('hidden');
            f.reset();
          } else {
            errorEl?.classList.remove('hidden');
          }
        } catch {
          errorEl?.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          if (btnText) btnText.textContent = f.querySelector<HTMLInputElement>('[name="servicio"][type="hidden"]') ? 'Solicitar Presupuesto' : 'Enviar Solicitud';
          if (btnIcon) (btnIcon as HTMLElement).textContent = 'send';
        }
      });
    });
  </script>
</body>
</html>
