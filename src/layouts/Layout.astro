---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  robots?: string;
}

const {
  title,
  description,
  canonicalUrl = "https://mimsistemas.com/",
  ogImage = "https://mimsistemas.com/og-image.jpg",
  robots = "index, follow",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="MIM Sistemas" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#002444" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon set -->
    <link rel="icon" href="/mimsistemas/favicon-32.png" sizes="32x32" />
    <link rel="icon" href="/mimsistemas/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/mimsistemas/apple-touch-icon.png" />
    <link rel="manifest" href="/mimsistemas/manifest.webmanifest" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Inter (400, 500, 600, 700, 900) — display=optional prevents CLS from font swap -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=optional"
      rel="stylesheet"
    />

    <!-- Material Symbols Outlined — display=optional prevents CLS -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=optional"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MIM Sistemas" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "MIM Sistemas",
      "legalName": "Mimtel Soluciones Globales S.L.",
      "url": "https://mimsistemas.com",
      "logo": "https://mimsistemas.com/favicon.svg",
      "foundingDate": "2003",
      "taxID": "B87897302",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+34912000002",
        "email": "info@mimsistemas.com",
        "contactType": "customer service",
        "areaServed": "ES",
        "availableLanguage": "Spanish"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Porto Lagos 9-11 posterior",
        "addressLocality": "Alcorcón",
        "addressRegion": "Madrid",
        "postalCode": "28924",
        "addressCountry": "ES"
      }
    })} />

    <!-- JSON-LD Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ElectricalContractor",
      "name": "MIM Sistemas",
      "url": "https://mimsistemas.com",
      "telephone": "+34912000002",
      "email": "info@mimsistemas.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Porto Lagos 9-11 posterior",
        "addressLocality": "Alcorcón",
        "addressRegion": "Madrid",
        "postalCode": "28924",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "40.3456",
        "longitude": "-3.8259"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "priceRange": "$$",
      "areaServed": {
        "@type": "State",
        "name": "Comunidad de Madrid"
      }
    })} />

    <!-- JSON-LD Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "MIM Sistemas",
      "url": "https://mimsistemas.com",
      "description": "Servicios técnicos integrales para comunidades de propietarios y empresas en Madrid."
    })} />

    <!-- Analytics: Plausible (cookie-free, GDPR compliant) -->
    <script defer data-domain="mimsistemas.com" src="https://plausible.io/js/script.js"></script>
  </head>

  <body class="bg-surface font-body text-on-surface antialiased">
    <!-- Skip to content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none"
    >Saltar al contenido principal</a>

    <slot />

    <script>
      // Scroll-triggered BlurFade animations (Magic UI pattern)
      const animObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              animObs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "-40px" }
      );

      document.querySelectorAll("[data-animate]").forEach((el) => animObs.observe(el));

      // NumberTicker animation (Magic UI pattern)
      function animateNumber(el: HTMLElement) {
        const target = parseInt(el.dataset.countTo || "0", 10);
        const prefix = el.dataset.countPrefix || "";
        const suffix = el.dataset.countSuffix || "";
        const useLocale = el.hasAttribute("data-count-locale");
        const duration = 2000;
        const start = performance.now();

        function update(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(target * eased);
          const formatted = useLocale
            ? current.toLocaleString("es-ES")
            : String(current);
          el.textContent = prefix + formatted + suffix;
          if (progress < 1) requestAnimationFrame(update);
        }

        requestAnimationFrame(update);
      }

      const countObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateNumber(entry.target as HTMLElement);
              countObs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.5 }
      );

      document.querySelectorAll("[data-count-to]").forEach((el) => countObs.observe(el));

      // OpnForm AJAX submission
      const OPNFORM_API = 'https://forms.optihost.pro/api';
      const OPNFORM_FIELD_MAP: Record<string, string> = {
        nombre: 'mim-nombre',
        telefono: 'mim-telefono',
        email: 'mim-email',
        servicio: 'mim-servicio',
        comunidad: 'mim-comunidad',
        mensaje: 'mim-mensaje',
        origen: 'mim-origen',
      };

      document.querySelectorAll('.opnform').forEach(form => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const f = e.target as HTMLFormElement;
          const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
          const btnText = btn.querySelector('.btn-text');
          const successEl = f.querySelector('.form-success') as HTMLElement;
          const errorEl = f.querySelector('.form-error') as HTMLElement;
          const originalText = btnText?.textContent || btn.textContent || '';
          const slug = f.dataset.opnformSlug;

          // Honeypot check
          const honeypot = f.querySelector<HTMLInputElement>('[name="botcheck"]');
          if (honeypot?.value) return;

          btn.disabled = true;
          if (btnText) btnText.textContent = 'Enviando...';
          else btn.textContent = 'Enviando...';
          successEl?.classList.add('hidden');
          errorEl?.classList.add('hidden');

          // Build payload with OpnForm field UUIDs
          const fd = new FormData(f);
          const payload: Record<string, string> = {};
          for (const [name, value] of fd.entries()) {
            const fieldId = OPNFORM_FIELD_MAP[name];
            if (fieldId && typeof value === 'string' && value.trim()) {
              let v = value.trim();
              // Normalize Spanish phone numbers to E.164
              if (name === 'telefono') {
                const digits = v.replace(/[\s\-().]/g, '');
                if (/^[67]\d{8}$/.test(digits)) v = '+34' + digits;
                else if (/^34[67]\d{8}$/.test(digits)) v = '+' + digits;
              }
              payload[fieldId] = v;
            }
          }

          try {
            const res = await fetch(`${OPNFORM_API}/forms/${slug}/answer`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json();
            if (res.ok && data.type === 'success') {
              successEl?.classList.remove('hidden');
              f.reset();
            } else {
              errorEl?.classList.remove('hidden');
            }
          } catch {
            errorEl?.classList.remove('hidden');
          } finally {
            btn.disabled = false;
            if (btnText) btnText.textContent = originalText;
            else btn.textContent = originalText;
          }
        });
      });
    </script>
  </body>
</html>
