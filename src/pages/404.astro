---
import LayoutV2 from '../layouts/LayoutV2.astro';
import HeaderV2 from '../components/v2/HeaderV2.astro';
import FooterV2 from '../components/v2/FooterV2.astro';
import '../styles/v2.css';
---

<LayoutV2 title="Página no encontrada | MIM Sistemas" description="La página que buscas no existe o ha sido movida." robots="noindex, nofollow">
  <HeaderV2 />
  <main id="main-content" class="min-h-screen flex items-center justify-center bg-surface px-6 pt-24">
    <div class="text-center max-w-lg">
      <div class="inline-flex items-center justify-center w-24 h-24 bg-accent/10 rounded-full mb-8">
        <span class="material-symbols-outlined text-5xl text-accent" aria-hidden="true">search_off</span>
      </div>
      <h1 class="font-heading text-7xl font-bold text-primary mb-4">404</h1>
      <p class="text-xl text-text font-heading font-medium mb-2">Página no encontrada</p>
      <p class="text-text-muted mb-10">
        La página que buscas no existe o ha sido movida. Pero no te preocupes, podemos ayudarte.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="v2-btn-cta text-base justify-center">
          <span class="material-symbols-outlined text-xl" aria-hidden="true">home</span>
          Volver al inicio
        </a>
        <a href="tel:912000002" class="v2-btn-outline text-base justify-center">
          <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
          912 000 002
        </a>
      </div>
    </div>
  </main>
  <FooterV2 />
</LayoutV2>
