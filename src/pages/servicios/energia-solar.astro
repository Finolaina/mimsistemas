            <div class="grid grid-cols-4 gap-6">
              {steps.map(step => (
                <div class="flex flex-col items-center text-center group cursor-default">
                  <div class="relative mb-8">
                    <div class="v2-timeline-dot group-hover:scale-110 transition-transform duration-300">
                      <span class="material-symbols-outlined text-xl text-white" aria-hidden="true">{step.icon}</span>
