---
/**
 * Service Landing Page: Energía Solar para Comunidades
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/energia-solar-comunidad-vecinos.png';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import showcaseImg from '../../assets/images/trabajo-energia-solar.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Energía Solar para Comunidades de Vecinos en Madrid",
  metaTitle: "Energía Solar para Comunidades de Vecinos en Madrid | MIM Sistemas",
  metaDescription: "Instalación de placas solares para comunidades de vecinos en Madrid. Autoconsumo colectivo, ahorro hasta 70% en electricidad, tramitación de subvenciones. Presupuesto gratis. 912 000 002",
  slug: "energia-solar",
  icon: "solar_power",
  badge: "Energía · Solar Fotovoltaica",
};

const painPoints = [
  { icon: "payments", title: "Factura eléctrica disparada", desc: "El coste de la electricidad no deja de subir y la factura de zonas comunes (ascensores, iluminación, bombas) se ha duplicado en pocos años." },
  { icon: "lightbulb", title: "Zonas comunes con alto consumo", desc: "Ascensores, iluminación de garaje, portales, bombas de agua y sistemas de climatización generan un consumo eléctrico elevado y constante." },
  { icon: "roofing", title: "Sin aprovechar la azotea", desc: "La azotea del edificio recibe cientos de horas de sol al año y no se aprovecha para generar energía limpia y gratuita." },
  { icon: "help", title: "Desconocimiento de subvenciones", desc: "Existen subvenciones europeas, estatales y autonómicas que pueden cubrir hasta el 40% de la inversión, pero muchas comunidades desconocen cómo acceder a ellas." },
];

const solutions = [
  { icon: "solar_power", title: "Autoconsumo colectivo", desc: "Instalación de paneles solares fotovoltaicos en la azotea comunitaria para alimentar las zonas comunes y repartir los excedentes entre los vecinos. Ahorro inmediato desde el primer mes.", featured: true },
  { icon: "battery_charging_full", title: "Baterías de almacenamiento", desc: "Sistemas de baterías que almacenan la energía sobrante para consumirla por la noche o en días nublados. Maximiza el aprovechamiento de cada kilovatio generado.", featured: true },
  { icon: "monitoring", title: "Monitorización en tiempo real", desc: "Plataforma de seguimiento online que permite ver la producción, el consumo y el ahorro en tiempo real desde el móvil o el ordenador.", featured: false },
  { icon: "swap_horiz", title: "Gestión de excedentes", desc: "Configuración del sistema para verter los excedentes a la red y obtener compensación en la factura eléctrica de la comunidad.", featured: false },
  { icon: "description", title: "Tramitación de subvenciones", desc: "Nos encargamos de toda la documentación y tramitación para acceder a las subvenciones disponibles: fondos europeos, Plan MOVES y ayudas autonómicas.", featured: false },
  { icon: "engineering", title: "Mantenimiento incluido", desc: "Contratos de mantenimiento que incluyen limpieza de paneles, revisión de inversores, monitorización remota y garantía de producción.", featured: false },
];

const benefits = [
  { icon: "savings", title: "Ahorro hasta 70%", desc: "Reduce la factura eléctrica de las zonas comunes hasta un 70% desde el primer mes de funcionamiento.", color: "accent" },
  { icon: "trending_up", title: "Revalorización inmueble", desc: "Las viviendas en edificios con energía solar se revalorizan entre un 3% y un 6% según estudios del mercado inmobiliario.", color: "cta" },
  { icon: "redeem", title: "Subvenciones disponibles", desc: "Accede a subvenciones que pueden cubrir hasta el 40% de la inversión. Nosotros tramitamos todo el proceso.", color: "success" },
  { icon: "eco", title: "Energía limpia", desc: "Reduce la huella de carbono de tu comunidad contribuyendo a la lucha contra el cambio climático con energía 100% renovable.", color: "accent-light" },
  { icon: "electric_bolt", title: "Independencia energética", desc: "Genera tu propia electricidad y reduce la dependencia de las subidas de precio de las eléctricas.", color: "accent" },
  { icon: "update", title: "ROI en 4-6 años", desc: "La inversión se amortiza en 4 a 6 años y los paneles tienen una vida útil de más de 25 años generando ahorro.", color: "cta" },
];

const steps = [
  { num: "01", title: "Estudio de viabilidad", desc: "Analizamos la azotea, la orientación, las sombras y el consumo eléctrico de la comunidad para dimensionar la instalación óptima.", icon: "search" },
  { num: "02", title: "Proyecto y subvenciones", desc: "Elaboramos el proyecto técnico, gestionamos las subvenciones disponibles y presentamos un presupuesto cerrado con el ahorro estimado.", icon: "assignment" },
  { num: "03", title: "Instalación profesional", desc: "Técnicos certificados instalan los paneles, inversores y el sistema de monitorización. Tramitamos la legalización ante Industria.", icon: "construction" },
  { num: "04", title: "Monitorización y soporte", desc: "Activamos la monitorización remota, formamos a la comunidad y ofrecemos mantenimiento preventivo para garantizar el rendimiento.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "Instalamos placas solares con MIM y el ahorro ha sido espectacular. La factura de zonas comunes ha bajado un 65%. Además, nos tramitaron la subvención y todo fue muy sencillo.",
    name: "Isabel Fernández",
    role: "Presidenta Comunidad, Pozuelo de Alarcón",
    initials: "IF"
  },
  {
    quote: "Como administrador, recomiendo MIM a todas mis comunidades. El estudio de viabilidad es muy completo, el presupuesto transparente y los resultados superan las expectativas. Ya van 8 comunidades solares.",
    name: "Andrés Molina",
    role: "Administrador de Fincas",
    initials: "AM"
  },
  {
    quote: "Los vecinos estaban escépticos al principio, pero cuando vieron la primera factura con el ahorro real, todos aplaudieron la decisión. MIM fue muy profesional en todo el proceso.",
    name: "Teresa Jiménez",
    role: "Presidenta Comunidad, Las Rozas",
    initials: "TJ"
  },
];

const faqs = [
  {
    q: "¿Cuánto cuesta instalar placas solares en una comunidad de vecinos?",
    a: "El coste depende del tamaño de la instalación y el consumo de la comunidad. Una instalación típica para zonas comunes de un edificio de 30 viviendas puede costar entre 15.000 € y 30.000 € antes de subvenciones. Con las ayudas disponibles, el coste final se reduce significativamente."
  },
  {
    q: "¿Qué subvenciones hay disponibles para energía solar en comunidades?",
    a: "Actualmente hay fondos europeos Next Generation, ayudas del Plan MOVES y subvenciones autonómicas de la Comunidad de Madrid que pueden cubrir entre el 30% y el 40% de la inversión. Además, existen bonificaciones en el IBI de muchos municipios. Nosotros nos encargamos de toda la tramitación."
  },
  {
    q: "¿Cuánto mantenimiento necesitan los paneles solares?",
    a: "Los paneles solares requieren un mantenimiento mínimo: limpieza periódica (1-2 veces al año), revisión de conexiones y monitorización del rendimiento. Los inversores se revisan anualmente. Con nuestro contrato de mantenimiento, nos encargamos de todo y garantizamos el rendimiento óptimo."
  },
  {
    q: "¿Es compatible la energía solar con la instalación eléctrica existente?",
    a: "Sí, la instalación solar se conecta al cuadro eléctrico existente de la comunidad sin necesidad de modificar la instalación interna. Se añade un inversor y un sistema de inyección que convierte la energía solar en electricidad compatible con la red. Nuestros técnicos evalúan la compatibilidad en la visita."
  },
  {
    q: "¿En cuánto tiempo se amortiza la inversión en placas solares?",
    a: "Con los precios actuales de la electricidad y las subvenciones disponibles, la inversión se amortiza típicamente en 4 a 6 años. Los paneles tienen una vida útil garantizada de 25 años, lo que significa más de 20 años de ahorro neto tras la amortización."
  },
  {
    q: "¿Hay que legalizar la instalación de placas solares?",
    a: "Sí, toda instalación de autoconsumo debe registrarse ante la Comunidad de Madrid y la distribuidora eléctrica. Nosotros nos encargamos de toda la tramitación: proyecto técnico, boletín eléctrico, registro en Industria y comunicación a la distribuidora. La comunidad no tiene que hacer ningún trámite."
  },
];

const relatedServices = [
  { icon: "bolt", title: "Electricidad", slug: "/mimsistemas/servicios/electricidad", desc: "Adecuación de la instalación eléctrica para la conexión solar." },
  { icon: "ev_station", title: "Puntos de Carga", slug: "/mimsistemas/servicios/puntos-de-carga", desc: "Carga tu coche eléctrico con la energía del sol." },
  { icon: "sensor_door", title: "Automatismos", slug: "/mimsistemas/servicios/automatismos", desc: "Alimenta tus automatismos con energía solar." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Energía Solar", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Energía Solar para Comunidades de Vecinos",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Energía Solar Fotovoltaica",
  "category": "Energía",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Instalaciones de Energía Solar",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo instalar placas solares en tu comunidad de vecinos",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Instalación de paneles solares fotovoltaicos en azotea de comunidad de vecinos en Madrid"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/mimsistemas/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/mimsistemas/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Energía Solar</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Energía Solar</span> para Comunidades de Vecinos en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Instalación de placas solares fotovoltaicas para comunidades de vecinos en Madrid. Autoconsumo colectivo que reduce la factura eléctrica hasta un 70%, tramitación completa de subvenciones y monitorización en tiempo real. Más de 20 años de experiencia en instalaciones eléctricas en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "description", text: "Subvenciones Gestionadas" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía 25 Años" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Estudio de Viabilidad Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Estudio de viabilidad gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un estudio personalizado.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="energia-solar" />
                <input type="hidden" name="origen" value="servicio-energia-solar" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Queremos estudiar la viabilidad de placas solares en nuestra comunidad de 40 viviendas..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/mimsistemas/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Estudio Gratuito</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need solar energy
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            El coste eléctrico es uno de los mayores gastos de las comunidades de vecinos en Madrid. La energía solar es la solución más rentable y sostenible.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
            <div class="v2-card-glow p-7 group cursor-default border border-red-200/30 group-hover:border-red-300/50 transition-all">
              <div class="w-14 h-14 bg-red-50 group-hover:bg-red-100 rounded-2xl flex items-center justify-center mb-5 transition-all">
