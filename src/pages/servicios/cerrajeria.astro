---
/**
 * Service Landing Page: Cerrajería Profesional
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/cerrajeria-cerradura-seguridad.png';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import showcaseImg from '../../assets/images/trabajo-cerrajeria.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Cerrajería Profesional para Comunidades en Madrid",
  metaTitle: "Cerrajería Profesional para Comunidades en Madrid | MIM Sistemas",
  metaDescription: "Servicio de cerrajería para comunidades y empresas en Madrid. Cerraduras de seguridad, bombillos antibumping, amaestramientos y urgencias 24h. Presupuesto gratis. 912 000 002",
  slug: "cerrajeria",
  icon: "lock",
  badge: "Seguridad · Cerrajería",
};

const painPoints = [
  { icon: "lock_open", title: "Cerraduras viejas fáciles de forzar", desc: "Las cerraduras antiguas del portal, garaje y trasteros se pueden abrir con métodos básicos, dejando la comunidad expuesta a intrusiones." },
  { icon: "key_off", title: "Llaves que no funcionan bien", desc: "Llaves desgastadas que se atascan, cerraduras que cuestan girar y mecanismos que fallan justo cuando más se necesitan." },
  { icon: "group_off", title: "Sin amaestramiento de accesos", desc: "Cada puerta tiene una llave diferente y no hay un sistema organizado de accesos. El presidente necesita un llavero enorme." },
  { icon: "emergency", title: "Urgencias fuera de horario", desc: "Un vecino se queda encerrado, se rompe la cerradura del portal o alguien pierde las llaves a las 3 de la mañana sin saber a quién llamar." },
];

const solutions = [
  { icon: "enhanced_encryption", title: "Cerraduras Antibumping", desc: "Instalación de cerraduras de alta seguridad con protección antibumping, antiganzúa y antiextracción. Certificadas según la norma UNE-EN 1303, las más resistentes del mercado para portales comunitarios.", featured: true },
  { icon: "vpn_key", title: "Amaestramiento de Llaves", desc: "Sistema de amaestramiento donde una llave maestra abre todas las puertas comunes (portal, garaje, trasteros) y cada vecino accede solo a sus zonas. Control total, máxima comodidad.", featured: true },
  { icon: "lock_person", title: "Bombillos de Alta Seguridad", desc: "Bombillos con tarjeta de propiedad que impiden la copia no autorizada. Solo el propietario puede solicitar duplicados.", featured: false },
  { icon: "smartphone", title: "Cerraduras Electrónicas", desc: "Cerraduras inteligentes con apertura por código, tarjeta o smartphone. Ideales para zonas comunes con alto tránsito.", featured: false },
  { icon: "nights_stay", title: "Apertura de Emergencia 24h", desc: "Servicio de cerrajería urgente las 24 horas del día, los 365 días del año. Apertura sin daños y asistencia inmediata.", featured: false },
  { icon: "security", title: "Refuerzo de Puertas", desc: "Instalación de escudos de seguridad, cerrojos de alta resistencia y refuerzos metálicos para puertas de portal y garaje.", featured: false },
];

const benefits = [
  { icon: "shield_lock", title: "Seguridad anti-rotura", desc: "Cerraduras certificadas con protección antibumping, antiganzúa y antiextracción que resisten los métodos de forzado más comunes.", color: "accent" },
  { icon: "vpn_key", title: "Un solo llavín maestro", desc: "Con el amaestramiento, una llave abre todo lo comunitario. Cada vecino solo accede a lo suyo. Sencillo y seguro.", color: "cta" },
  { icon: "schedule", title: "Urgencias 24 horas", desc: "Servicio de emergencia disponible día y noche, festivos incluidos. Un cerrajero profesional cuando lo necesites.", color: "success" },
  { icon: "block", title: "Sin copias no autorizadas", desc: "Bombillos con tarjeta de propiedad que impiden que nadie haga copias sin tu autorización expresa.", color: "accent-light" },
  { icon: "door_front", title: "Puertas reforzadas", desc: "Escudos de seguridad y cerrojos de alta resistencia que convierten las puertas existentes en barreras infranqueables.", color: "accent" },
  { icon: "favorite", title: "Tranquilidad total", desc: "La seguridad de saber que tu comunidad está protegida con los sistemas de cerrajería más avanzados del mercado.", color: "cta" },
];

const steps = [
  { num: "01", title: "Consulta gratuita", desc: "Nos cuentas las necesidades de seguridad de tu comunidad. Evaluamos el estado de cerraduras y accesos actuales.", icon: "call" },
  { num: "02", title: "Proyecto y presupuesto", desc: "Un cerrajero profesional visita el edificio, analiza cada acceso y presenta un presupuesto cerrado sin compromiso.", icon: "assignment" },
  { num: "03", title: "Instalación profesional", desc: "Cerrajeros propios instalan las cerraduras y sistemas de seguridad con materiales de primera calidad y acabados impecables.", icon: "construction" },
  { num: "04", title: "Entrega y soporte", desc: "Entregamos llaves, tarjetas de propiedad y documentación. Servicio de urgencias 24h y asistencia post-instalación.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "MIM nos hizo el amaestramiento completo del edificio: portal, garaje, cuarto de contadores y trasteros. Ahora cada vecino lleva una sola llave para todo. Comodísimo y mucho más seguro.",
    name: "Isabel Fernández",
    role: "Presidenta Comunidad, Fuenlabrada",
    initials: "IF"
  },
  {
    quote: "Nos intentaron forzar el portal dos veces. Llamamos a MIM, pusieron cerraduras antibumping y escudos de seguridad. Desde entonces, ni un solo intento. Gran trabajo.",
    name: "David Moreno",
    role: "Presidente Comunidad, Parla",
    initials: "DM"
  },
  {
    quote: "Se nos rompió la cerradura del garaje un sábado por la noche. Llamé a MIM y en 45 minutos tenía un cerrajero arreglándolo. Servicio de urgencias de verdad, no como otros.",
    name: "Susana Gil",
    role: "Vecina Comunidad, Getafe",
    initials: "SG"
  },
];

const faqs = [
  {
    q: "¿Qué es un amaestramiento de llaves y cómo funciona?",
    a: "El amaestramiento es un sistema donde se crea una jerarquía de llaves: una llave maestra que abre todas las puertas comunitarias y llaves individuales que solo abren las zonas asignadas a cada vecino. Es el sistema más eficiente para gestionar accesos en comunidades, eliminando la necesidad de múltiples llaves."
  },
  {
    q: "¿Cuánto cuesta cambiar las cerraduras de una comunidad?",
    a: "El coste depende del número de accesos y el tipo de cerradura. Un cambio de cerradura antibumping para el portal puede partir desde 150 €. Un amaestramiento completo para un edificio de 20 vecinos suele oscilar entre 2.000 € y 4.000 €. Presupuesto gratuito y sin compromiso."
  },
  {
    q: "¿Cuánto tardáis en llegar en caso de urgencia?",
    a: "Nuestro tiempo medio de respuesta en urgencias es de 30 a 60 minutos en todo Madrid y municipios del sur. Disponemos de cerrajeros de guardia las 24 horas, los 365 días del año, incluidos festivos y fines de semana."
  },
  {
    q: "¿Qué es una cerradura antibumping y por qué la necesito?",
    a: "El bumping es una técnica que permite abrir cerraduras convencionales con una llave especial en segundos. Las cerraduras antibumping incorporan mecanismos que bloquean este método, además de proteger contra ganzúas y extracción del bombillo. Son imprescindibles para la seguridad de portales comunitarios."
  },
  {
    q: "¿Se pueden blindar las puertas existentes sin cambiarlas?",
    a: "Sí, en la mayoría de casos podemos reforzar las puertas existentes con escudos de seguridad, cerrojos de alta resistencia, placas antipalanca y refuerzos metálicos. Es una solución más económica que sustituir la puerta completa y ofrece un nivel de seguridad muy alto."
  },
  {
    q: "¿Cuánto tiempo tarda la instalación de un amaestramiento?",
    a: "Un amaestramiento completo para un edificio de 20-30 vecinos se realiza habitualmente en 2-3 días laborables. Planificamos la instalación por fases para que los vecinos no se queden sin acceso en ningún momento y entregamos las nuevas llaves de forma organizada."
  },
];

const relatedServices = [
  { icon: "lock_open", title: "Control de Accesos", slug: "/servicios/control-de-accesos", desc: "Complementa la cerrajería con sistemas electrónicos de control de accesos." },
  { icon: "dialpad", title: "Porteros Automáticos", slug: "/servicios/porteros-automaticos", desc: "Videoporteros modernos para controlar quién accede a tu edificio." },
  { icon: "videocam", title: "Videovigilancia", slug: "/servicios/videovigilancia", desc: "Cámaras de seguridad para monitorizar accesos y zonas comunes." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Cerrajería", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Cerrajería Profesional para Comunidades",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Cerrajería Profesional",
  "category": "Seguridad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Cerrajería",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo securizar los accesos de tu comunidad con cerrajería profesional",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Cerrajero profesional instalando cerradura de alta seguridad en puerta de comunidad"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Cerrajería</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Cerrajería Profesional</span> para Comunidades en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Servicio de cerrajería profesional para comunidades de propietarios y empresas en Madrid. Cerraduras antibumping, amaestramiento de llaves, bombillos de alta seguridad y urgencias 24 horas. Más de 20 años protegiendo edificios en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "schedule", text: "Urgencias 24h" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía Escrita" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Solicitar Presupuesto Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Presupuesto gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un presupuesto a medida.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="cerrajeria" />
                <input type="hidden" name="origen" value="servicio-cerrajeria" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Queremos cambiar las cerraduras del portal y hacer un amaestramiento para toda la comunidad..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Presupuesto</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need this service
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            La mayoría de comunidades en Madrid mantienen cerraduras de hace décadas, vulnerables a técnicas de forzado modernas y sin un sistema de llaves organizado.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
            <div class="v2-card-glow p-7 group cursor-default border border-red-200/30 group-hover:border-red-300/50 transition-all">
              <div class="w-14 h-14 bg-red-50 group-hover:bg-red-100 rounded-2xl flex items-center justify-center mb-5 transition-all">
                <span class="material-symbols-outlined text-2xl text-red-500 group-hover:scale-110 transition-transform" aria-hidden="true">{p.icon}</span>
              </div>
