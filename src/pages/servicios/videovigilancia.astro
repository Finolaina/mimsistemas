---
/**
 * Service Landing Page: Videovigilancia y CCTV
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/videovigilancia-cctv-madrid.png';
import showcaseImg from '../../assets/images/trabajo-videovigilancia-cctv.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Videovigilancia y CCTV para Comunidades en Madrid",
  metaTitle: "Videovigilancia y CCTV para Comunidades en Madrid | MIM Sistemas",
  metaDescription: "Instalación profesional de sistemas de videovigilancia CCTV para comunidades y empresas en Madrid. Cámaras IP 4K, grabadores NVR, acceso remoto desde el móvil. Presupuesto gratis. 912 000 002",
  slug: "videovigilancia",
  icon: "videocam",
  badge: "Seguridad · Videovigilancia",
};

const painPoints = [
  { icon: "warning", title: "Vandalismo sin pruebas", desc: "Se producen actos vandálicos en zonas comunes, garajes y portales pero no hay forma de identificar a los responsables ni aportar pruebas." },
  { icon: "visibility_off", title: "Zonas oscuras sin vigilancia", desc: "Garajes, accesos traseros y zonas comunes quedan completamente desprotegidos al no contar con ningún sistema de vigilancia activo." },
  { icon: "no_backpack", title: "Robos en garajes y trasteros", desc: "Los robos en plazas de garaje y trasteros son cada vez más frecuentes, generando inseguridad y pérdidas económicas a los vecinos." },
  { icon: "videocam_off", title: "Sistemas obsoletos sin grabación", desc: "Muchas comunidades tienen cámaras antiguas analógicas que no graban, no tienen resolución útil o directamente están fuera de servicio." },
];

const solutions = [
  { icon: "camera_outdoor", title: "Cámaras IP 4K", desc: "Cámaras de última generación con resolución 4K Ultra HD, visión nocturna avanzada y gran angular. Imagen nítida de día y de noche para identificar personas y matrículas.", featured: true },
  { icon: "hard_drive", title: "Grabadores NVR", desc: "Grabadores en red de alta capacidad con almacenamiento de hasta 30 días. Búsqueda inteligente por fecha, hora o zona. Redundancia de datos para máxima seguridad.", featured: true },
  { icon: "dome_light", title: "Cámaras domo antivandálicas", desc: "Cámaras con carcasa reforzada IK10 resistente a impactos y manipulación. Ideales para zonas de riesgo como garajes y accesos.", featured: false },
  { icon: "nightlight", title: "Videovigilancia nocturna IR", desc: "Tecnología infrarroja de última generación que ofrece imágenes nítidas en completa oscuridad, sin necesidad de iluminación adicional.", featured: false },
  { icon: "smartphone", title: "Acceso remoto app móvil", desc: "Visualiza las cámaras en directo desde tu smartphone o tablet, estés donde estés. Recibe alertas de movimiento al instante.", featured: false },
  { icon: "smart_display", title: "Analítica de vídeo IA", desc: "Detección inteligente de intrusión, merodeo y objetos abandonados. Reduce falsas alarmas y automatiza la vigilancia.", featured: false },
];

const benefits = [
  { icon: "shield", title: "Disuasión total", desc: "La presencia de cámaras visibles reduce drásticamente los actos vandálicos y los intentos de robo en la comunidad.", color: "accent" },
  { icon: "gavel", title: "Pruebas legales", desc: "Las grabaciones en alta definición sirven como prueba válida ante denuncias, seguros y procedimientos judiciales.", color: "cta" },
  { icon: "schedule", title: "Vigilancia 24/7", desc: "Tu comunidad protegida las 24 horas del día, los 365 días del año, sin interrupciones ni turnos de vigilancia.", color: "success" },
  { icon: "phone_iphone", title: "Acceso remoto", desc: "Consulta las cámaras en directo y revisa las grabaciones desde cualquier lugar con tu smartphone.", color: "accent-light" },
  { icon: "savings", title: "Ahorro en seguros", desc: "Las aseguradoras aplican descuentos significativos a comunidades con sistemas de videovigilancia certificados.", color: "accent" },
  { icon: "link", title: "Integración con accesos", desc: "Combina la videovigilancia con el control de accesos para una seguridad completa y centralizada.", color: "cta" },
];

const steps = [
  { num: "01", title: "Consulta gratuita", desc: "Analizamos las necesidades de seguridad de tu comunidad y las zonas a vigilar: accesos, garajes, perímetro.", icon: "call" },
  { num: "02", title: "Proyecto y presupuesto", desc: "Un técnico visita la comunidad, estudia la ubicación óptima de cada cámara y entrega un presupuesto cerrado.", icon: "assignment" },
  { num: "03", title: "Instalación profesional", desc: "Instalación por técnicos propios con cableado oculto, configuración de grabación y acceso remoto incluido.", icon: "construction" },
  { num: "04", title: "Soporte y mantenimiento", desc: "Formación al presidente y conserje. Mantenimiento preventivo, limpieza de cámaras y soporte técnico continuo.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "Desde que MIM instaló las cámaras, no hemos vuelto a tener ni un solo acto vandálico en el garaje. La calidad de imagen es increíble, se ve todo perfectamente incluso de noche.",
    name: "Carmen Delgado",
    role: "Presidenta Comunidad, Getafe",
    initials: "CD"
  },
  {
    quote: "Como administrador, lo que más valoro es poder enseñar las grabaciones a los vecinos cuando hay una incidencia. Se acabaron las discusiones. MIM fue rápido y muy profesional.",
    name: "Miguel Ángel Torres",
    role: "Administrador de Fincas",
    initials: "MT"
  },
  {
    quote: "Llevábamos años con unas cámaras antiguas que no grababan nada. MIM nos modernizó todo el sistema y ahora lo vemos desde el móvil. Los vecinos están muy tranquilos.",
    name: "Ana Belén Ruiz",
    role: "Presidenta Comunidad, Leganés",
    initials: "AR"
  },
];

const faqs = [
  {
    q: "¿Es legal instalar cámaras de videovigilancia en una comunidad de vecinos?",
    a: "Sí, es legal siempre que se cumplan los requisitos de la LOPD y el RGPD. Las cámaras solo pueden enfocar zonas comunes, nunca la vía pública ni espacios privados de otros vecinos. Es obligatorio colocar carteles informativos y registrar el tratamiento de datos. Nosotros nos encargamos de toda la documentación legal."
  },
  {
    q: "¿Qué zonas comunes se pueden vigilar con cámaras?",
    a: "Se pueden vigilar todas las zonas comunes de la comunidad: accesos peatonales, garaje, trasteros, piscina, jardín, azotea y pasillos. Las cámaras no pueden enfocar puertas de viviendas individuales ni espacios de la vía pública. Diseñamos la ubicación para maximizar la cobertura respetando la normativa."
  },
  {
    q: "¿Cuántos días se almacenan las grabaciones?",
    a: "Por ley, las grabaciones pueden almacenarse un máximo de 30 días, tras los cuales se borran automáticamente. Nuestros grabadores NVR se configuran para gestionar este ciclo de forma automática. En caso de incidencia, las grabaciones relevantes pueden extraerse y conservarse como prueba."
  },
  {
    q: "¿Cuánto cuesta un sistema de videovigilancia para una comunidad?",
    a: "El precio depende del número de cámaras, la resolución elegida y la complejidad de la instalación. Un sistema básico de 4 cámaras IP con grabador NVR puede empezar desde 1.800 € para comunidades pequeñas. Realizamos un estudio gratuito y entregamos presupuesto cerrado sin compromiso."
  },
  {
    q: "¿Qué mantenimiento necesitan las cámaras de seguridad?",
    a: "Recomendamos un mantenimiento preventivo semestral que incluye limpieza de lentes, verificación de enfoque y ángulo, actualización de firmware y revisión del grabador. Nuestros contratos de mantenimiento incluyen todo esto más la reparación de averías con tiempo de respuesta garantizado."
  },
  {
    q: "¿Se puede aprovechar el cableado de un sistema de cámaras antiguo?",
    a: "En muchos casos sí. Si la comunidad tiene cableado coaxial en buen estado, podemos reutilizarlo con conversores o, si es cableado de red, conectar directamente las nuevas cámaras IP. Nuestros técnicos evalúan el estado del cableado existente en la visita gratuita para minimizar la obra."
  },
];

const relatedServices = [
  { icon: "lock_open", title: "Control de Accesos", slug: "/servicios/control-de-accesos", desc: "Complementa la videovigilancia con control de quién entra y sale." },
  { icon: "dialpad", title: "Porteros Automáticos", slug: "/servicios/porteros-automaticos", desc: "Videoporteros modernos integrados con tu sistema de seguridad." },
  { icon: "bolt", title: "Electricidad", slug: "/servicios/electricidad", desc: "Instalación eléctrica profesional para alimentar tu sistema CCTV." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Videovigilancia y CCTV", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Videovigilancia y CCTV para Comunidades",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Videovigilancia y CCTV",
  "category": "Seguridad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Sistemas de Videovigilancia y CCTV",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo instalar un sistema de videovigilancia en tu comunidad",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Sistema de videovigilancia CCTV profesional instalado en edificio residencial en Madrid"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Videovigilancia y CCTV</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Videovigilancia</span> y CCTV para Comunidades en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Instalación profesional de sistemas de videovigilancia CCTV para comunidades de propietarios y empresas en Madrid. Cámaras IP 4K, grabadores NVR, visión nocturna y acceso remoto desde el móvil. Más de 20 años protegiendo edificios en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "schedule", text: "Urgencias 24h" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía Escrita" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Solicitar Presupuesto Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Presupuesto gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un presupuesto a medida.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="videovigilancia" />
                <input type="hidden" name="origen" value="servicio-videovigilancia" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Necesitamos cámaras para el garaje y los accesos de la comunidad..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Presupuesto</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need video surveillance
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            La mayoría de comunidades en Madrid carecen de videovigilancia eficaz, dejando zonas comunes expuestas a robos, vandalismo e inseguridad.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
            <div class="v2-card-glow p-7 group cursor-default border border-red-200/30 group-hover:border-red-300/50 transition-all">
              <div class="w-14 h-14 bg-red-50 group-hover:bg-red-100 rounded-2xl flex items-center justify-center mb-5 transition-all">
