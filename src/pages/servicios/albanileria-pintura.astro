---
/**
 * Service Landing Page: Albañilería y Pintura
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/albanileria-pintura-fachada-edificio.png';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import showcaseImg from '../../assets/images/trabajo-albanileria-fachada.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Albañilería y Pintura para Comunidades en Madrid",
  metaTitle: "Albañilería y Pintura para Comunidades en Madrid | MIM Sistemas",
  metaDescription: "Servicios de albañilería y pintura para comunidades en Madrid. Rehabilitación de fachadas, pintura de portales, reparación de humedades y reformas integrales. Presupuesto gratis. 912 000 002",
  slug: "albanileria-pintura",
  icon: "format_paint",
  badge: "Reformas · Albañilería y Pintura",
};

const painPoints = [
  { icon: "wall", title: "Fachada deteriorada y desconchada", desc: "La fachada del edificio presenta desconchones, grietas y zonas ennegrecidas que dan una imagen de abandono y reducen el valor del inmueble." },
  { icon: "water_drop", title: "Humedades en zonas comunes", desc: "Manchas de humedad en portales, garajes y escaleras que generan malos olores, deterioran los materiales y pueden afectar la salud de los vecinos." },
  { icon: "door_front", title: "Portal anticuado y descuidado", desc: "El portal y las zonas comunes están anticuados: pintura descolorida, zócalos rotos y un aspecto general que no representa la calidad de vida de la comunidad." },
  { icon: "warning", title: "Grietas y filtraciones", desc: "Grietas en fachadas y cubiertas que provocan filtraciones de agua, dañan las estructuras internas y generan costosas reparaciones de urgencia." },
];

const solutions = [
  { icon: "apartment", title: "Rehabilitación de Fachadas", desc: "Rehabilitación integral de fachadas con reparación de grietas, saneamiento del enfoscado, aplicación de revestimientos transpirables y pintura de máxima durabilidad. Andamios, medios auxiliares y tramitación de licencias incluidos.", featured: true },
  { icon: "format_paint", title: "Pintura de Portales y Escaleras", desc: "Transformación completa de portales y escaleras con tratamiento previo de superficies, imprimación profesional y pintura de alta calidad. Acabados decorativos, zócalos y molduras para un resultado impecable.", featured: true },
  { icon: "water_drop", title: "Reparación de Humedades", desc: "Diagnóstico del origen de las humedades y tratamiento definitivo: impermeabilización, inyección de resinas, cámaras de ventilación y pinturas antihumedad.", featured: false },
  { icon: "roofing", title: "Impermeabilización de Cubiertas", desc: "Impermeabilización de terrazas, azoteas y cubiertas planas con láminas asfálticas, poliuretano proyectado o caucho líquido de máxima garantía.", featured: false },
  { icon: "home_repair_service", title: "Reformas de Zonas Comunes", desc: "Reformas integrales de cuartos de contadores, trasteros, salas de reuniones y cualquier espacio comunitario. Albañilería, fontanería y acabados.", featured: false },
  { icon: "construction", title: "Trabajos de Albañilería General", desc: "Reparación de aceras, muros, vallas, rampas de accesibilidad, arquetas y cualquier trabajo de albañilería que necesite tu comunidad.", featured: false },
];

const benefits = [
  { icon: "apartment", title: "Fachada como nueva", desc: "Rehabilitación profesional que devuelve a tu edificio su aspecto original o lo mejora con acabados modernos y duraderos.", color: "accent" },
  { icon: "water_drop", title: "Sin humedades", desc: "Diagnóstico y tratamiento definitivo que elimina las humedades de raíz, no solo los síntomas visibles.", color: "cta" },
  { icon: "door_front", title: "Portal renovado", desc: "Un portal limpio, moderno y bien cuidado que mejora la primera impresión y la calidad de vida de los vecinos.", color: "success" },
  { icon: "trending_up", title: "Revalorización inmueble", desc: "Un edificio bien mantenido puede revalorizarse entre un 10% y un 20%. La inversión se recupera en valor patrimonial.", color: "accent-light" },
  { icon: "task_alt", title: "ITE favorable", desc: "Fachadas y zonas comunes en buen estado son imprescindibles para superar la Inspección Técnica de Edificios sin problemas.", color: "accent" },
  { icon: "groups", title: "Comunidad orgullosa", desc: "Un edificio cuidado genera orgullo de pertenencia y mejora la convivencia entre los vecinos de la comunidad.", color: "cta" },
];

const steps = [
  { num: "01", title: "Consulta gratuita", desc: "Nos cuentas las necesidades de tu comunidad. Evaluamos el estado del edificio y detectamos las prioridades de actuación.", icon: "call" },
  { num: "02", title: "Proyecto y presupuesto", desc: "Un técnico visita el edificio, toma mediciones, evalúa patologías y entrega un presupuesto cerrado detallado sin compromiso.", icon: "assignment" },
  { num: "03", title: "Ejecución de obra", desc: "Albañiles y pintores propios ejecutan los trabajos con materiales de primera calidad, cumpliendo plazos y minimizando molestias.", icon: "construction" },
  { num: "04", title: "Entrega y garantía", desc: "Revisión final conjunta con la comunidad, limpieza completa y entrega con garantía escrita sobre materiales y mano de obra.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "MIM rehabilitó la fachada completa de nuestro edificio de 8 plantas. Andamios, pintura, reparación de grietas... todo impecable. Los vecinos no se lo creían cuando vieron el resultado. Parece un edificio nuevo.",
    name: "Rosa María Delgado",
    role: "Presidenta Comunidad, Leganés",
    initials: "RD"
  },
  {
    quote: "Teníamos humedades en el garaje desde hacía años y nadie daba con la solución. MIM diagnosticó el problema real, impermeabilizó la cubierta y trataron las paredes. Dos años después, ni una mancha.",
    name: "Andrés Vega",
    role: "Administrador de Fincas, Fuenlabrada",
    initials: "AV"
  },
  {
    quote: "Nos pintaron el portal, las escaleras y pusieron zócalos nuevos. La diferencia es brutal. Ahora da gusto entrar en el edificio y los vecinos cuidan mucho más las zonas comunes. Gran trabajo de MIM.",
    name: "Beatriz Castro",
    role: "Presidenta Comunidad, Getafe",
    initials: "BC"
  },
];

const faqs = [
  {
    q: "¿Cuánto cuesta rehabilitar la fachada de un edificio?",
    a: "El coste depende del tamaño del edificio, el estado de la fachada y el tipo de acabado. Como referencia, la rehabilitación de una fachada de un edificio de 20 viviendas y 6 plantas suele oscilar entre 25.000 € y 50.000 €. Realizamos un estudio gratuito y presentamos presupuesto cerrado."
  },
  {
    q: "¿Cómo se solucionan las humedades de forma definitiva?",
    a: "Primero diagnosticamos el origen exacto: filtraciones, capilaridad, condensación o rotura de tuberías. Después aplicamos el tratamiento específico: impermeabilización, inyección de resinas, cámaras de ventilación o reparación de canalizaciones. Tratamos la causa, no solo el síntoma."
  },
  {
    q: "¿Necesita licencia la rehabilitación de fachada?",
    a: "Sí, en Madrid la rehabilitación de fachadas requiere licencia de obra o comunicación previa según el alcance de los trabajos. Nosotros nos encargamos de toda la tramitación ante el Ayuntamiento, incluyendo proyecto técnico si es necesario. El coste de la licencia se incluye en el presupuesto."
  },
  {
    q: "¿Cuánto tiempo dura la rehabilitación de una fachada?",
    a: "El plazo depende del tamaño del edificio y la complejidad de los trabajos. Una fachada estándar de un edificio de 6 plantas suele completarse en 4-8 semanas. Montaje y desmontaje de andamios incluidos. Planificamos para minimizar las molestias a los vecinos."
  },
  {
    q: "¿La rehabilitación de fachada ayuda a pasar la ITE?",
    a: "Sí, la fachada es uno de los elementos principales que se evalúan en la Inspección Técnica de Edificios (ITE). Una fachada en buen estado, sin grietas ni desprendimientos, es fundamental para obtener un resultado favorable. Muchas comunidades nos contratan específicamente para preparar el edificio para la ITE."
  },
  {
    q: "¿Cuánto dura la pintura en una fachada?",
    a: "Con los materiales y la preparación adecuada, la pintura de una fachada puede durar entre 8 y 15 años. Utilizamos pinturas transpirables de silicona o siloxano de primera calidad, con tratamiento previo de fisuras y aplicación de imprimación. La garantía sobre nuestros trabajos es de 5 años."
  },
];

const relatedServices = [
  { icon: "electrical_services", title: "Electricidad", slug: "/servicios/electricidad", desc: "Aprovecha la reforma para modernizar la instalación eléctrica y el alumbrado LED." },
  { icon: "lock", title: "Cerrajería", slug: "/servicios/cerrajeria", desc: "Renueva las cerraduras del portal junto con la reforma de zonas comunes." },
  { icon: "solar_power", title: "Energía Solar", slug: "/servicios/energia-solar", desc: "Instala paneles solares en la cubierta durante la rehabilitación de fachada." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Albañilería y Pintura", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Albañilería y Pintura para Comunidades",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos, 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Comunidad de Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Albañilería y Pintura",
  "category": "Reformas",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Albañilería y Pintura",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo rehabilitar la fachada y zonas comunes de tu comunidad",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Rehabilitación y pintura de fachada de edificio de comunidad de vecinos en Madrid"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Albañilería y Pintura</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Albañilería y Pintura</span> para Comunidades en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Servicios profesionales de albañilería y pintura para comunidades de propietarios en Madrid. Rehabilitación de fachadas, pintura de portales, reparación de humedades e impermeabilización de cubiertas. Más de 20 años renovando edificios en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "schedule", text: "Urgencias 24h" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía Escrita" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Solicitar Presupuesto Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Presupuesto gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un presupuesto a medida.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="albanileria-pintura" />
                <input type="hidden" name="origen" value="servicio-albanileria-pintura" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Necesitamos rehabilitar la fachada y pintar el portal de la comunidad..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Presupuesto</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need this service
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            Muchos edificios en Madrid necesitan una renovación urgente de fachada y zonas comunes para mantener su valor y cumplir con la normativa.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
