---
/**
 * Service Landing Page: Control de Accesos
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/instalacion-videoportero-ip.png';
import showcaseImg from '../../assets/images/trabajo-control-accesos.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Control de Accesos para Comunidades en Madrid",
  metaTitle: "Control de Accesos para Comunidades en Madrid | MIM Sistemas",
  metaDescription: "Instalación y mantenimiento de sistemas de control de accesos para comunidades y empresas en Madrid. Videoporteros, lectores biométricos, barreras y tornos. Presupuesto gratis. 912 000 002",
  slug: "control-de-accesos",
  icon: "lock_open",
  badge: "Seguridad · Control de Accesos",
};

const painPoints = [
  { icon: "warning", title: "Accesos no controlados", desc: "Personas no autorizadas entran en zonas comunes, garajes y portales sin ningún tipo de registro ni control." },
  { icon: "key_off", title: "Llaves perdidas y copias", desc: "Las llaves físicas se pierden, se copian sin control y es imposible saber quién tiene acceso real al edificio." },
  { icon: "schedule", title: "Sin horarios de acceso", desc: "No puedes limitar el acceso a instalaciones como piscina, gimnasio o trasteros en horarios determinados." },
  { icon: "shield", title: "Vecinos inseguros", desc: "La falta de control genera una sensación de inseguridad que afecta la calidad de vida de toda la comunidad." },
];

const solutions = [
  { icon: "dialpad", title: "Videoporteros IP", desc: "Sistemas de videoportero con pantalla táctil, apertura remota desde el móvil y grabación de visitantes. Compatible con placas de calle de alta definición.", featured: true },
  { icon: "fingerprint", title: "Lectores Biométricos", desc: "Acceso por huella dactilar, reconocimiento facial o iris. Máxima seguridad sin llaves ni tarjetas que perder o copiar.", featured: true },
  { icon: "credit_card", title: "Tarjetas y Mandos", desc: "Sistemas de proximidad RFID con tarjetas, llaveros o mandos. Gestión centralizada de altas, bajas y permisos.", featured: false },
  { icon: "smartphone", title: "Acceso por Móvil", desc: "Apertura desde el smartphone vía Bluetooth o código QR. Ideal para visitas y servicios temporales.", featured: false },
  { icon: "garage", title: "Barreras y Puertas", desc: "Automatización de barreras vehiculares, puertas de garaje y tornos peatonales con control centralizado.", featured: false },
  { icon: "desktop_windows", title: "Software de Gestión", desc: "Plataforma centralizada para administrar usuarios, horarios, permisos y generar informes de acceso.", featured: false },
];

const benefits = [
  { icon: "verified_user", title: "Seguridad total", desc: "Control absoluto sobre quién entra y sale de tu comunidad, las 24 horas del día.", color: "accent" },
  { icon: "key_off", title: "Adiós a las llaves", desc: "Elimina el problema de las llaves perdidas y las copias no autorizadas.", color: "cta" },
  { icon: "schedule", title: "Horarios programables", desc: "Define horarios de acceso para cada zona: piscina, gimnasio, trasteros, garaje.", color: "success" },
  { icon: "monitoring", title: "Registro de accesos", desc: "Historial completo de quién ha accedido, cuándo y por dónde. Auditable.", color: "accent-light" },
  { icon: "phone_iphone", title: "Control remoto", desc: "Gestiona los accesos desde tu móvil. Abre a visitantes sin estar en casa.", color: "accent" },
  { icon: "savings", title: "Ahorro a largo plazo", desc: "Elimina el coste de copiar llaves y cambiar bombillos. Gestión digital sin coste recurrente.", color: "cta" },
];

const steps = [
  { num: "01", title: "Consulta gratuita", desc: "Nos cuentas las necesidades de tu comunidad. Analizamos el edificio y las zonas a controlar.", icon: "call" },
  { num: "02", title: "Proyecto y presupuesto", desc: "Un técnico visita la comunidad, diseña la solución y entrega un presupuesto cerrado sin compromiso.", icon: "assignment" },
  { num: "03", title: "Instalación profesional", desc: "Técnicos propios realizan la instalación con materiales de primera calidad y mínima molestia.", icon: "construction" },
  { num: "04", title: "Formación y soporte", desc: "Enseñamos a la comunidad a usar el sistema. Soporte técnico y mantenimiento incluido.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "Desde que instalamos el sistema de accesos con MIM, no hemos tenido ni un solo incidente de seguridad. Los vecinos están encantados con la app del móvil.",
    name: "Laura Martín",
    role: "Presidenta Comunidad, Alcorcón",
    initials: "LM"
  },
  {
    quote: "Gestionamos 15 comunidades con MIM y el control de accesos ha sido una revolución. Menos incidencias, menos quejas y todo controlado desde una plataforma.",
    name: "Fede Alonso",
    role: "Administrador de Fincas",
    initials: "FA"
  },
  {
    quote: "El cambio de llaves a tarjetas fue rapidísimo. En una semana toda la comunidad tenía su tarjeta y el portal, garaje y piscina funcionando perfectamente.",
    name: "Roberto Sánchez",
    role: "Presidente Comunidad, Móstoles",
    initials: "RS"
  },
];

const faqs = [
  {
    q: "¿Cuánto cuesta instalar un sistema de control de accesos en una comunidad?",
    a: "El coste depende del número de accesos a controlar, el tipo de tecnología elegida y el tamaño de la comunidad. Realizamos un estudio gratuito y presentamos un presupuesto cerrado sin compromiso. Como referencia, un sistema básico de tarjetas para portal y garaje puede empezar desde 1.500 € para comunidades pequeñas."
  },
  {
    q: "¿Se puede instalar sin hacer obra?",
    a: "Sí, en la mayoría de casos la instalación se realiza aprovechando el cableado existente del portero automático. En casos donde se requiere nuevo cableado, utilizamos canaletas para minimizar la obra. Nuestros técnicos evalúan la mejor opción en la visita gratuita."
  },
  {
    q: "¿Qué pasa si un vecino pierde su tarjeta o mando?",
    a: "A diferencia de las llaves físicas, las tarjetas perdidas se anulan inmediatamente desde el software de gestión, sin necesidad de cambiar cerraduras. Se emite una nueva tarjeta al vecino y la anterior queda inutilizada al instante."
  },
  {
    q: "¿El sistema funciona si se va la luz?",
    a: "Todos nuestros sistemas incluyen batería de respaldo (SAI) que garantiza el funcionamiento durante un mínimo de 4 horas sin electricidad. En caso de emergencia, los accesos se desbloquean automáticamente según la normativa de seguridad."
  },
  {
    q: "¿Se puede controlar el acceso a zonas específicas como piscina o gimnasio?",
    a: "Sí, el sistema permite crear zonas independientes con permisos y horarios específicos. Por ejemplo, acceso a la piscina solo en verano de 10:00 a 21:00, o al gimnasio solo para los vecinos que hayan pagado la cuota correspondiente."
  },
  {
    q: "¿Ofrecéis mantenimiento del sistema?",
    a: "Sí, ofrecemos contratos de mantenimiento preventivo y correctivo. Incluyen revisiones periódicas, actualizaciones de software, reparación de averías y atención de urgencias 24h. Más del 90% de nuestras comunidades contratan el mantenimiento para garantizar el funcionamiento continuo."
  },
];

const relatedServices = [
  { icon: "videocam", title: "CCTV y Videovigilancia", slug: "/servicios/videovigilancia", desc: "Complementa el control de accesos con cámaras de seguridad." },
  { icon: "dialpad", title: "Porteros Automáticos", slug: "/servicios/porteros-automaticos", desc: "Videoporteros modernos para tu comunidad." },
  { icon: "sensor_door", title: "Automatismos", slug: "/servicios/automatismos", desc: "Puertas de garaje y automatización de accesos." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Control de Accesos", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Control de Accesos para Comunidades",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Control de Accesos",
  "category": "Seguridad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Sistemas de Control de Accesos",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo instalar un sistema de control de accesos en tu comunidad",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Técnico instalando sistema de videoportero IP en portal de comunidad de propietarios"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/mimsistemas/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Control de Accesos</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Control de Accesos</span> para Comunidades y Empresas en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Instalación profesional de sistemas de control de accesos para comunidades de propietarios y empresas en Madrid. Videoporteros IP, lectores biométricos, tarjetas RFID y apertura desde el móvil. Más de 20 años securizando edificios en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "schedule", text: "Urgencias 24h" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía Escrita" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Solicitar Presupuesto Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Presupuesto gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un presupuesto a medida.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="control-de-accesos" />
                <input type="hidden" name="origen" value="servicio-control-de-accesos" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Queremos cambiar las llaves del portal y garaje por tarjetas..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/mimsistemas/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Presupuesto</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need access control
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            La mayoría de comunidades en Madrid siguen usando llaves físicas, un sistema obsoleto que genera inseguridad y costes innecesarios.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
            <div class="v2-card-glow p-7 group cursor-default border border-red-200/30 group-hover:border-red-300/50 transition-all">
              <div class="w-14 h-14 bg-red-50 group-hover:bg-red-100 rounded-2xl flex items-center justify-center mb-5 transition-all">
                <span class="material-symbols-outlined text-2xl text-red-500 group-hover:scale-110 transition-transform" aria-hidden="true">{p.icon}</span>
              </div>
              <h3 class="font-heading font-semibold text-primary text-lg mb-2">{p.title}</h3>
              <p class="text-text-muted text-sm leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        SOLUTIONS — Types of access control
    ═══════════════════════════════════════════ */}
    <div class="relative -mb-1">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 60V20C240 0 480 40 720 30C960 20 1200 0 1440 20V60H0Z" fill="white"/>
      </svg>
    </div>

    <section class="relative py-20 md:py-28 bg-surface overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-40" aria-hidden="true"></div>

