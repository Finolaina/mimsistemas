---
/**
 * Service Landing Page: Electricidad e Instalaciones LED
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: Service + BreadcrumbList + FAQPage + HowTo schemas
 */
import LayoutV2 from '../../layouts/LayoutV2.astro';
import HeaderV2 from '../../components/v2/HeaderV2.astro';
import FooterV2 from '../../components/v2/FooterV2.astro';
import FloatingV2 from '../../components/v2/FloatingV2.astro';
import { Image } from 'astro:assets';
import whatsappIcon from '../../assets/images/whatsapp-cta-icon.png';
import heroImg from '../../assets/images/instalacion-electrica-cuadro-led.png';
import WorkShowcaseV2 from '../../components/v2/WorkShowcaseV2.astro';
import showcaseImg from '../../assets/images/trabajo-electricidad.png';
import '../../styles/v2.css';

/* ── Service Data (easy to replicate for other services) ── */

const service = {
  title: "Instalaciones Eléctricas y LED para Comunidades en Madrid",
  metaTitle: "Instalaciones Eléctricas y LED para Comunidades en Madrid | MIM Sistemas",
  metaDescription: "Electricistas profesionales para comunidades y empresas en Madrid. Instalaciones eléctricas, cuadros, iluminación LED, boletines y certificados. Presupuesto gratis. 912 000 002",
  slug: "electricidad",
  icon: "electrical_services",
  badge: "Electricidad · Instalaciones LED",
};

const painPoints = [
  { icon: "warning", title: "Instalación eléctrica obsoleta", desc: "Cableado antiguo con riesgo de cortocircuitos, sobrecargas y averías constantes que ponen en peligro a toda la comunidad." },
  { icon: "power_off", title: "Apagones frecuentes", desc: "Cortes de luz recurrentes en zonas comunes, garajes y ascensores que afectan al día a día de los vecinos." },
  { icon: "light_off", title: "Iluminación deficiente en zonas comunes", desc: "Portales, escaleras y garajes con poca luz que generan sensación de inseguridad y dificultan la movilidad." },
  { icon: "payments", title: "Facturas de luz elevadas", desc: "Consumo eléctrico disparado por luminarias obsoletas y sistemas ineficientes que encarecen las cuotas de la comunidad." },
];

const solutions = [
  { icon: "electric_meter", title: "Renovación de Cuadros Eléctricos", desc: "Sustitución completa de cuadros eléctricos comunitarios con protecciones diferenciales, magnetotérmicos y cumplimiento del REBT. Eliminamos riesgos y garantizamos la seguridad de toda la instalación.", featured: true },
  { icon: "fluorescent", title: "Iluminación LED Comunitaria", desc: "Cambio integral a tecnología LED en portales, escaleras, garajes y zonas comunes. Ahorro de hasta el 80% en consumo eléctrico con una vida útil de más de 50.000 horas.", featured: true },
  { icon: "cable", title: "Líneas Nuevas y Ampliaciones", desc: "Tendido de nuevas líneas eléctricas y ampliaciones de potencia para garajes, ascensores, piscinas o zonas de recarga.", featured: false },
  { icon: "description", title: "Boletines y Certificados", desc: "Tramitación de boletines eléctricos, certificados de instalación y legalización ante la Comunidad de Madrid.", featured: false },
  { icon: "troubleshoot", title: "Detección de Averías", desc: "Localización rápida de averías con equipos de medición profesional. Reparación inmediata para minimizar tiempos sin servicio.", featured: false },
  { icon: "timer", title: "Automatización de Iluminación", desc: "Sensores de presencia, temporizadores y reguladores para encender la luz solo cuando se necesita y ahorrar energía.", featured: false },
];

const benefits = [
  { icon: "health_and_safety", title: "Seguridad eléctrica", desc: "Instalación revisada y certificada según normativa REBT vigente. Protección total frente a sobrecargas y cortocircuitos.", color: "accent" },
  { icon: "savings", title: "Ahorro en consumo", desc: "Reduce la factura eléctrica de la comunidad hasta un 80% con iluminación LED y automatización inteligente.", color: "cta" },
  { icon: "gavel", title: "Cumplimiento normativo", desc: "Boletines, certificados y legalizaciones al día. Sin riesgo de sanciones ni problemas con la ITE.", color: "success" },
  { icon: "lightbulb", title: "Iluminación óptima", desc: "Zonas comunes bien iluminadas que mejoran la seguridad, la convivencia y la estética del edificio.", color: "accent-light" },
  { icon: "update", title: "Mayor durabilidad", desc: "Materiales de primera calidad y tecnología LED con más de 50.000 horas de vida útil sin mantenimiento.", color: "accent" },
  { icon: "trending_up", title: "Valor del inmueble", desc: "Una instalación eléctrica moderna y certificada revaloriza el edificio y facilita la venta o alquiler de viviendas.", color: "cta" },
];

const steps = [
  { num: "01", title: "Consulta gratuita", desc: "Nos cuentas las necesidades eléctricas de tu comunidad. Evaluamos el estado actual y detectamos puntos de mejora.", icon: "call" },
  { num: "02", title: "Proyecto y presupuesto", desc: "Un electricista titulado visita el edificio, diseña la solución y entrega un presupuesto cerrado sin compromiso.", icon: "assignment" },
  { num: "03", title: "Instalación profesional", desc: "Electricistas propios con carné profesional realizan la instalación cumpliendo toda la normativa REBT vigente.", icon: "construction" },
  { num: "04", title: "Certificación y soporte", desc: "Entregamos boletines y certificados oficiales. Soporte técnico y mantenimiento preventivo incluido.", icon: "support_agent" },
];

const testimonials = [
  {
    quote: "Cambiamos todo el cuadro eléctrico y la iluminación a LED con MIM. La diferencia es brutal: el portal parece otro y la factura de luz ha bajado un 70%. Muy profesionales.",
    name: "Carmen Ruiz",
    role: "Presidenta Comunidad, Getafe",
    initials: "CR"
  },
  {
    quote: "Teníamos apagones constantes en el garaje y el ascensor se quedaba parado. MIM renovó toda la instalación en una semana y desde entonces cero problemas. Totalmente recomendables.",
    name: "Miguel Ángel Torres",
    role: "Administrador de Fincas, Leganés",
    initials: "MT"
  },
  {
    quote: "Nos tramitaron el boletín eléctrico para la ITE y además nos propusieron el cambio a LED. Ahorramos más de 200 € al mes en electricidad. Una inversión que se paga sola.",
    name: "Patricia Navarro",
    role: "Presidenta Comunidad, Majadahonda",
    initials: "PN"
  },
];

const faqs = [
  {
    q: "¿Qué certificados necesita la instalación eléctrica de una comunidad?",
    a: "La instalación eléctrica comunitaria requiere un boletín de instalación eléctrica (BIE) y, en caso de reforma, un certificado de instalación eléctrica (CIE) emitido por un instalador autorizado. Estos certificados son necesarios para superar la ITE y cumplir con el REBT. Nosotros nos encargamos de toda la tramitación."
  },
  {
    q: "¿Cuánto se ahorra al cambiar a iluminación LED en una comunidad?",
    a: "El ahorro medio al cambiar de luminarias convencionales a LED oscila entre el 60% y el 80% del consumo en iluminación. En una comunidad media de 30 vecinos esto puede suponer entre 150 € y 300 € al mes. La inversión se amortiza habitualmente en menos de 18 meses."
  },
  {
    q: "¿Cuánto cuesta renovar el cuadro eléctrico de una comunidad?",
    a: "El coste depende del tamaño de la comunidad y el estado de la instalación. Un cuadro eléctrico general con protecciones actualizadas puede partir desde 1.200 € para comunidades pequeñas. Realizamos un estudio gratuito y presentamos presupuesto cerrado."
  },
  {
    q: "¿Cuánto tiempo tarda la instalación?",
    a: "Un cambio de cuadro eléctrico se realiza normalmente en 1-2 días. La sustitución de iluminación LED en zonas comunes puede completarse en 2-5 días dependiendo del número de plantas. Planificamos los trabajos para minimizar las molestias a los vecinos."
  },
  {
    q: "¿Atendéis emergencias eléctricas fuera de horario?",
    a: "Sí, disponemos de servicio de urgencias eléctricas 24 horas para nuestras comunidades. Un técnico se desplaza en el menor tiempo posible para resolver cortocircuitos, apagones o cualquier avería eléctrica urgente que afecte a la seguridad."
  },
  {
    q: "¿Qué normativa se aplica a las instalaciones eléctricas comunitarias?",
    a: "Las instalaciones eléctricas de comunidades de propietarios se rigen por el Reglamento Electrotécnico de Baja Tensión (REBT) y sus Instrucciones Técnicas Complementarias (ITC-BT). Todos nuestros trabajos se realizan cumpliendo escrupulosamente esta normativa y con instaladores autorizados."
  },
];

const relatedServices = [
  { icon: "solar_power", title: "Energía Solar", slug: "/servicios/energia-solar", desc: "Complementa tu instalación eléctrica con paneles solares para autoconsumo comunitario." },
  { icon: "ev_station", title: "Puntos de Carga", slug: "/servicios/puntos-de-carga", desc: "Instalación de puntos de recarga para vehículos eléctricos en garajes comunitarios." },
  { icon: "settings_input_antenna", title: "Antenización", slug: "/servicios/antenizacion", desc: "Instalación y mantenimiento de antenas TDT y telecomunicaciones para tu edificio." },
];

/* ── Color mapping for benefits ── */
const colorMap: Record<string, { iconBg: string; border: string }> = {
  accent: { iconBg: "bg-accent/10 group-hover:bg-accent/20", border: "border-accent/20 group-hover:border-accent/40" },
  cta: { iconBg: "bg-cta/10 group-hover:bg-cta/20", border: "border-cta/20 group-hover:border-cta/40" },
  success: { iconBg: "bg-success/10 group-hover:bg-success/20", border: "border-success/20 group-hover:border-success/40" },
  "accent-light": { iconBg: "bg-accent-light/10 group-hover:bg-accent-light/20", border: "border-accent-light/20 group-hover:border-accent-light/40" },
};

/* ── JSON-LD Schemas ── */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://mimsistemas.com/#servicios" },
    { "@type": "ListItem", "position": 3, "name": "Electricidad", "item": `https://mimsistemas.com/servicios/${service.slug}` },
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Instalaciones Eléctricas y LED para Comunidades",
  "description": service.metaDescription,
  "url": `https://mimsistemas.com/servicios/${service.slug}`,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Porto Lagos 9-11 posterior",
      "addressLocality": "Alcorcón",
      "addressRegion": "Madrid",
      "postalCode": "28924",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "40.3456", "longitude": "-3.8259" }
  },
  "areaServed": { "@type": "State", "name": "Comunidad de Madrid" },
  "serviceType": "Instalaciones Eléctricas y LED",
  "category": "Electricidad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Electricidad y LED",
    "itemListElement": solutions.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.desc }
    }))
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo renovar la instalación eléctrica de tu comunidad",
  "step": steps.map(s => ({
    "@type": "HowToStep",
    "position": parseInt(s.num),
    "name": s.title,
    "text": s.desc
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<LayoutV2
  title={service.metaTitle}
  description={service.metaDescription}
  robots="index, follow"
  canonicalUrl={`https://mimsistemas.com/servicios/${service.slug}`}
>
  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeaderV2 />

  <main id="main-content">
    {/* ═══════════════════════════════════════════
        HERO — Service-specific with breadcrumbs
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[85vh] flex items-center overflow-hidden">
      <!-- Background Image with gradient overlay -->
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Electricista profesional trabajando en cuadro eléctrico de comunidad de vecinos"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary-light/90 to-primary/70"></div>
      </div>

      <!-- Floating shapes -->
      <div class="v2-float-shape v2-float-1 top-[15%] right-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-2 top-[60%] right-[5%] w-16 h-16 border border-cta/20 rounded-full" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-3 top-[30%] left-[5%] w-12 h-12 bg-accent/10 rounded-xl rotate-45" aria-hidden="true"></div>
      <div class="v2-float-shape v2-float-1 bottom-[20%] left-[8%] w-24 h-24 border border-accent/10 rounded-full" aria-hidden="true"></div>

      <!-- Blobs -->
      <div class="v2-blob w-[400px] h-[400px] bg-accent/15 top-[-10%] right-[-5%]" aria-hidden="true"></div>
      <div class="v2-blob w-[300px] h-[300px] bg-cta/10 bottom-[-5%] left-[-5%]" style="animation-delay: -4s;" aria-hidden="true"></div>

      <!-- Dot grid -->
      <div class="absolute inset-0 v2-dot-pattern-light opacity-25" aria-hidden="true"></div>

      <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 pt-28 pb-16 lg:pt-32 lg:pb-20">
        <!-- Breadcrumbs -->
        <nav class="mb-8 v2-hero-entrance" aria-label="Migas de pan">
          <ol class="flex items-center gap-2 text-sm text-white/50">
            <li><a href="/mimsistemas/" class="hover:text-white/80 transition-colors">Inicio</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li><a href="/#servicios" class="hover:text-white/80 transition-colors">Servicios</a></li>
            <li aria-hidden="true"><span class="material-symbols-outlined text-xs">chevron_right</span></li>
            <li class="text-white/80 font-medium">Electricidad</li>
          </ol>
        </nav>

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 text-white v2-hero-entrance">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-5 py-2 mb-8">
              <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{service.icon}</span>
              <span class="text-sm font-medium text-white/90 tracking-wide">{service.badge}</span>
            </div>

            <!-- H1 -->
            <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl font-bold leading-[1.1] mb-6">
              <span class="v2-gradient-text">Instalaciones Eléctricas y LED</span> para Comunidades en Madrid
            </h1>

            <!-- SEO paragraph (keyword in first 100 words) -->
            <p class="text-lg lg:text-xl text-white/75 leading-relaxed max-w-xl mb-10">
              Electricistas profesionales para comunidades de propietarios y empresas en Madrid. Renovación de cuadros eléctricos, iluminación LED, boletines y certificados. Más de 20 años garantizando la seguridad eléctrica de edificios en la Comunidad de Madrid.
            </p>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
              {[
                { icon: "engineering", text: "Técnicos Propios" },
                { icon: "schedule", text: "Urgencias 24h" },
                { icon: "request_quote", text: "Presupuesto Cerrado" },
                { icon: "workspace_premium", text: "Garantía Escrita" }
              ].map(badge => (
                <div class="flex items-center gap-2.5 bg-white/8 backdrop-blur-sm border border-white/10 rounded-xl px-3 py-2.5">
                  <span class="material-symbols-outlined text-cta text-lg" aria-hidden="true">{badge.icon}</span>
                  <span class="text-xs font-medium text-white/85 leading-tight">{badge.text}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="#presupuesto" class="v2-btn-cta text-base">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
                Solicitar Presupuesto Gratis
              </a>
              <a href="tel:912000002" class="v2-btn-outline !border-white/30 !text-white hover:!bg-white/15 hover:!text-white text-base backdrop-blur-sm">
                <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
                912 000 002
              </a>
            </div>
          </div>

          <!-- Right: Lead Form -->
          <div class="lg:col-span-5" id="presupuesto">
            <div class="v2-form-card p-6 sm:p-8">
              <h2 class="font-heading text-xl font-bold text-primary mb-1">Presupuesto gratuito</h2>
              <p class="text-sm text-text-muted mb-6">Te contactamos en menos de 1 hora con un presupuesto a medida.</p>

              <form class="flex flex-col gap-4 opnform" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
                <input type="hidden" name="servicio" value="electricidad" />
                <input type="hidden" name="origen" value="servicio-electricidad" />
                <!-- Honeypot anti-spam -->
                <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
                </div>
                <div>
                  <label for="svc-name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
                  <input type="text" id="svc-name" name="nombre" placeholder="Ej: Juan García" autocomplete="name"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
                  <input type="tel" id="svc-phone" name="telefono" placeholder="600 000 000" autocomplete="tel"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" required />
                </div>
                <div>
                  <label for="svc-email" class="block text-sm font-medium text-text mb-1.5">Email <span class="text-text-muted font-normal">(opcional)</span></label>
                  <input type="email" id="svc-email" name="email" placeholder="email@ejemplo.com" autocomplete="email"
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all" />
                </div>
                <div>
                  <label for="svc-message" class="block text-sm font-medium text-text mb-1.5">¿Qué necesitas?</label>
                  <textarea id="svc-message" name="mensaje" rows="3" placeholder="Ej: Necesitamos renovar el cuadro eléctrico y cambiar a LED las zonas comunes..."
                    class="w-full px-4 py-3 bg-surface-alt border border-border rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-all resize-none"></textarea>
                </div>
                <!-- RGPD consent -->
                <label class="flex items-start gap-2.5 cursor-pointer">
                  <input type="checkbox" name="rgpd" required
                    class="mt-0.5 w-4 h-4 rounded border-border text-accent focus:ring-accent/30 cursor-pointer" />
                  <span class="text-xs text-text-muted leading-relaxed">
                    Acepto la <a href="/mimsistemas/politica-privacidad" target="_blank" class="text-accent underline hover:text-accent-light">Política de Privacidad</a> y consiento el tratamiento de mis datos para gestionar mi solicitud.
                  </span>
                </label>
                <button type="submit" class="v2-btn-cta w-full justify-center text-base mt-1">
                  <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                  <span class="btn-text">Solicitar Presupuesto</span>
                </button>
                <!-- Success/error messages -->
                <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                  <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                  <p class="text-sm font-medium text-green-800">¡Solicitud enviada! Te contactaremos en menos de 1 hora.</p>
                </div>
                <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                  <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                  <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        PAIN POINTS — Why you need this service
    ═══════════════════════════════════════════ */}
    <section class="relative py-20 md:py-28 bg-white overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16 v2-reveal">
          <span class="v2-section-label">El Problema</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-primary mt-3 mb-4">
            ¿Tu comunidad tiene
            <span class="v2-gradient-text">estos problemas</span>?
          </h2>
          <p class="text-text-muted max-w-2xl mx-auto text-lg">
            Muchas comunidades en Madrid arrastran instalaciones eléctricas de hace décadas, con riesgos reales y gastos innecesarios que se pueden evitar.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {painPoints.map(p => (
            <div class="v2-card-glow p-7 group cursor-default border border-red-200/30 group-hover:border-red-300/50 transition-all">
              <div class="w-14 h-14 bg-red-50 group-hover:bg-red-100 rounded-2xl flex items-center justify-center mb-5 transition-all">
                <span class="material-symbols-outlined text-2xl text-red-500 group-hover:scale-110 transition-transform" aria-hidden="true">{p.icon}</span>
              </div>
              <h3 class="font-heading font-semibold text-primary text-lg mb-2">{p.title}</h3>
