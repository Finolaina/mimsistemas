---
/**
 * Contact Page — "Contacto"
 * Design System: V2 "Trust Shield Deluxe"
 * SEO: LocalBusiness + BreadcrumbList + ContactPage schemas
 */
import LayoutV2 from '../layouts/LayoutV2.astro';
import HeaderV2 from '../components/v2/HeaderV2.astro';
import FooterV2 from '../components/v2/FooterV2.astro';
import FloatingV2 from '../components/v2/FloatingV2.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/contacto-equipo-mim-sistemas.png';
import whatsappIcon from '../assets/images/whatsapp-cta-icon.png';
import '../styles/v2.css';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mimsistemas.com" },
    { "@type": "ListItem", "position": 2, "name": "Contacto", "item": "https://mimsistemas.com/contacto" },
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ElectricalContractor",
  "name": "MIM Sistemas",
  "alternateName": "Mimtel Soluciones Globales S.L.",
  "url": "https://mimsistemas.com",
  "telephone": "+34912000002",
  "email": "info@mimsistemas.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle Porto Lagos 9-11 posterior",
    "addressLocality": "Alcorcón",
    "addressRegion": "Madrid",
    "postalCode": "28924",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.3456,
    "longitude": -3.8318
  },
  "areaServed": {
    "@type": "State",
    "name": "Comunidad de Madrid"
  },
  "foundingDate": "2003",
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "hasMap": "https://share.google/HEbzCYd0Zc8a1M1Ma",
  "sameAs": ["https://share.google/HEbzCYd0Zc8a1M1Ma"]
};

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contacto — MIM Sistemas",
  "description": "Contacta con MIM Sistemas para servicios técnicos en comunidades de Madrid. Presupuesto gratuito sin compromiso.",
  "url": "https://mimsistemas.com/contacto",
  "mainEntity": {
    "@type": "Organization",
    "name": "MIM Sistemas",
    "telephone": "+34912000002",
    "email": "info@mimsistemas.com"
  }
};

const services = [
  "Control de Accesos",
  "Videovigilancia CCTV",
  "Porteros Automáticos",
  "Automatismos",
  "Energía Solar",
  "Puntos de Carga EV",
  "Electricidad y LED",
  "Antenización TDT",
  "Cerrajería",
  "Megafonía",
  "Albañilería y Pintura",
];

const trustSignals = [
  { icon: "schedule", value: "< 1 hora", label: "Tiempo de respuesta" },
  { icon: "verified", value: "20+ años", label: "De experiencia" },
  { icon: "groups", value: "500+", label: "Comunidades atendidas" },
  { icon: "workspace_premium", value: "100%", label: "Presupuestos gratis" },
];
---

<LayoutV2
  title="Contacto — MIM Sistemas · Presupuesto Gratis en Madrid"
  description="Contacta con MIM Sistemas para servicios técnicos en comunidades y empresas de Madrid. Presupuesto gratuito sin compromiso. Llámanos al 912 000 002."
  robots="index, follow"
  canonicalUrl="https://mimsistemas.com/contacto"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <HeaderV2 />

  <main id="main-content">

    {/* ═══════════════════════════════════════════
        HERO — Slim contact hero
    ═══════════════════════════════════════════ */}
    <section class="relative min-h-[50vh] md:min-h-[45vh] flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Equipo de MIM Sistemas en su oficina de Alcorcón, Madrid"
          class="w-full h-full object-cover"
          widths={[640, 1024, 1440, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/75 to-primary/60"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-32 md:py-36 w-full">
        <nav class="mb-6 v2-reveal" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-sm text-white/60">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li><span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></li>
            <li class="text-white font-medium">Contacto</li>
          </ol>
        </nav>

        <div class="max-w-2xl v2-reveal">
          <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-white/90 text-sm font-heading font-semibold mb-4">
            <span class="material-symbols-outlined text-cta text-base" aria-hidden="true">support_agent</span>
            Estamos aquí para ayudarte
          </span>
          <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4">
            Contacta con <span class="text-cta">Nosotros</span>
          </h1>
          <p class="text-lg text-white/80 leading-relaxed">
            Cuéntanos qué necesita tu comunidad. Te respondemos en menos de 1 hora con un presupuesto personalizado y sin compromiso.
          </p>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        CONTACT CARDS — Phone, Email, WhatsApp, Location
    ═══════════════════════════════════════════ */}
    <section class="relative -mt-12 z-20 pb-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 v2-stagger">
          <!-- Phone -->
          <a href="tel:912000002" class="v2-card-glow p-6 flex items-center gap-4 group cursor-pointer hover:border-accent/30 transition-all">
            <div class="w-14 h-14 bg-accent/10 group-hover:bg-accent/20 rounded-2xl flex items-center justify-center flex-shrink-0 transition-colors">
              <span class="material-symbols-outlined text-2xl text-accent group-hover:scale-110 transition-transform" aria-hidden="true">call</span>
            </div>
            <div>
              <p class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-0.5">Teléfono</p>
              <p class="font-heading font-bold text-primary text-lg group-hover:text-accent transition-colors">912 000 002</p>
              <p class="text-xs text-text-muted">L-V de 8:00 a 18:00</p>
            </div>
          </a>

          <!-- WhatsApp -->
          <a href="https://wa.me/34912000002" target="_blank" rel="noopener noreferrer" class="v2-card-glow p-6 flex items-center gap-4 group cursor-pointer hover:border-[#25D366]/30 transition-all">
            <div class="w-14 h-14 bg-[#25D366]/10 group-hover:bg-[#25D366]/20 rounded-2xl flex items-center justify-center flex-shrink-0 transition-colors">
              <Image src={whatsappIcon} alt="" width={28} height={28} class="group-hover:scale-110 transition-transform" />
            </div>
            <div>
              <p class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-0.5">WhatsApp</p>
              <p class="font-heading font-bold text-primary text-lg group-hover:text-[#25D366] transition-colors">Enviar mensaje</p>
              <p class="text-xs text-text-muted">Respuesta inmediata</p>
            </div>
          </a>

          <!-- Email -->
          <a href="mailto:info@mimsistemas.com" class="v2-card-glow p-6 flex items-center gap-4 group cursor-pointer hover:border-cta/30 transition-all">
            <div class="w-14 h-14 bg-cta/10 group-hover:bg-cta/20 rounded-2xl flex items-center justify-center flex-shrink-0 transition-colors">
              <span class="material-symbols-outlined text-2xl text-cta group-hover:scale-110 transition-transform" aria-hidden="true">mail</span>
            </div>
            <div class="min-w-0">
              <p class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-0.5">Email</p>
              <p class="font-heading font-bold text-primary text-lg group-hover:text-cta transition-colors">Enviar email</p>
              <p class="text-xs text-text-muted truncate">info@mimsistemas.com</p>
            </div>
          </a>

          <!-- Location -->
          <a href="https://maps.google.com/?q=Calle+Porto+Lagos+9-11+Alcorcon+Madrid" target="_blank" rel="noopener noreferrer" class="v2-card-glow p-6 flex items-center gap-4 group cursor-pointer hover:border-success/30 transition-all">
            <div class="w-14 h-14 bg-success/10 group-hover:bg-success/20 rounded-2xl flex items-center justify-center flex-shrink-0 transition-colors">
              <span class="material-symbols-outlined text-2xl text-success group-hover:scale-110 transition-transform" aria-hidden="true">location_on</span>
            </div>
            <div>
              <p class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-0.5">Oficina</p>
              <p class="font-heading font-bold text-primary text-base group-hover:text-success transition-colors">C/ Porto Lagos 9-11</p>
              <p class="text-xs text-text-muted">28924 Alcorcón, Madrid</p>
            </div>
          </a>
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        MAIN FORM + MAP — Two column layout
    ═══════════════════════════════════════════ */}
    <section class="relative py-16 md:py-24 bg-white overflow-hidden">
      <div class="v2-blob w-[400px] h-[400px] bg-accent/8 -top-[10%] -right-[8%]" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

          {/* ── Contact Form (3 cols) ── */}
          <div class="lg:col-span-3 v2-reveal-left">
            <span class="v2-section-label">Escríbenos</span>
            <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mt-3 mb-3 leading-tight">
              Solicita tu <span class="v2-gradient-text">Presupuesto Gratis</span>
            </h2>
            <p class="text-text-muted mb-8">
              Rellena el formulario y te contactaremos en menos de 1 hora laborable con una propuesta personalizada para tu comunidad.
            </p>

            <form class="opnform space-y-5" data-opnform-slug="contacto-mim-sistemas-qxnrgn" method="POST">
              <input type="hidden" name="origen" value="contacto" />
              <!-- Honeypot -->
              <div class="!absolute !w-px !h-px !overflow-hidden !whitespace-nowrap" style="clip: rect(0,0,0,0); border: 0;" aria-hidden="true">
                <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="contact-nombre" class="block text-sm font-heading font-semibold text-primary mb-1.5">Nombre completo *</label>
                  <input type="text" id="contact-nombre" name="nombre" required placeholder="Tu nombre"
                    class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary placeholder:text-text-muted/50 focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm" />
                </div>
                <div>
                  <label for="contact-telefono" class="block text-sm font-heading font-semibold text-primary mb-1.5">Teléfono *</label>
                  <input type="tel" id="contact-telefono" name="telefono" required placeholder="612 345 678"
                    class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary placeholder:text-text-muted/50 focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm" />
                </div>
              </div>

              <div>
                <label for="contact-email" class="block text-sm font-heading font-semibold text-primary mb-1.5">Email</label>
                <input type="email" id="contact-email" name="email" placeholder="tu@email.com"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary placeholder:text-text-muted/50 focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm" />
              </div>

              <div>
                <label for="contact-servicio" class="block text-sm font-heading font-semibold text-primary mb-1.5">Servicio de interés</label>
                <select id="contact-servicio" name="servicio"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm">
                  <option value="">Selecciona un servicio (opcional)</option>
                  {services.map(s => (
                    <option value={s}>{s}</option>
                  ))}
                  <option value="Otro">Otro / Varios servicios</option>
                </select>
              </div>

              <div>
                <label for="contact-comunidad" class="block text-sm font-heading font-semibold text-primary mb-1.5">Nombre de la comunidad / dirección</label>
                <input type="text" id="contact-comunidad" name="comunidad" placeholder="Ej: Comunidad C/ Gran Vía 10, Madrid"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary placeholder:text-text-muted/50 focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm" />
              </div>

              <div>
                <label for="contact-mensaje" class="block text-sm font-heading font-semibold text-primary mb-1.5">Cuéntanos qué necesitas *</label>
                <textarea id="contact-mensaje" name="mensaje" required rows="4" placeholder="Describe brevemente lo que necesita tu comunidad..."
                  class="w-full px-4 py-3 rounded-xl border border-border bg-white text-primary placeholder:text-text-muted/50 focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all text-sm resize-y"></textarea>
              </div>

              <!-- RGPD -->
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="rgpd" required
                  class="mt-1 w-4 h-4 rounded border-border text-accent focus:ring-accent/20 flex-shrink-0" />
                <span class="text-xs text-text-muted leading-relaxed group-hover:text-text transition-colors">
                  He leído y acepto la <a href="/politica-privacidad" class="text-accent underline hover:text-accent-light">Política de Privacidad</a>.
                  Tus datos serán tratados por Mimtel Soluciones Globales S.L. para gestionar tu solicitud.
                </span>
              </label>

              <button type="submit" class="v2-btn-cta text-base w-full sm:w-auto justify-center">
                <span class="material-symbols-outlined text-xl btn-icon" aria-hidden="true">send</span>
                <span class="btn-text">Enviar Solicitud</span>
              </button>

              <div class="form-success hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
                <span class="material-symbols-outlined text-green-600 text-2xl mb-1" aria-hidden="true">check_circle</span>
                <p class="text-sm font-medium text-green-800">¡Solicitud enviada correctamente! Te contactaremos en menos de 1 hora.</p>
              </div>
              <div class="form-error hidden rounded-xl bg-red-50 border border-red-200 p-4 text-center">
                <span class="material-symbols-outlined text-red-600 text-2xl mb-1" aria-hidden="true">error</span>
                <p class="text-sm font-medium text-red-800">Error al enviar. Llámanos al <a href="tel:912000002" class="underline">912 000 002</a>.</p>
              </div>
            </form>
          </div>

          {/* ── Map + Info (2 cols) ── */}
          <div class="lg:col-span-2 v2-reveal-right">
            <div class="sticky top-28 space-y-6">
              <!-- Google Maps embed -->
              <div class="rounded-2xl overflow-hidden shadow-lg border border-border">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3040.5!2d-3.8318!3d40.3456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sCalle+Porto+Lagos+9-11%2C+28924+Alcorc%C3%B3n!5e0!3m2!1ses!2ses!4v1"
                  width="100%"
                  height="300"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Ubicación de MIM Sistemas en Alcorcón, Madrid"
                  class="w-full"
                ></iframe>
              </div>

              <!-- Office info card -->
              <div class="v2-card-glow p-6">
                <h3 class="font-heading font-semibold text-primary text-lg mb-4 flex items-center gap-2">
                  <span class="material-symbols-outlined text-accent" aria-hidden="true">business</span>
                  Nuestra Oficina
                </h3>
                <ul class="space-y-4 text-sm">
                  <li class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-accent text-lg flex-shrink-0 mt-0.5" aria-hidden="true">location_on</span>
                    <div>
                      <p class="font-medium text-primary">Calle Porto Lagos, 9-11 posterior</p>
                      <p class="text-text-muted">28924 Alcorcón, Madrid</p>
                    </div>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-accent text-lg flex-shrink-0 mt-0.5" aria-hidden="true">schedule</span>
                    <div>
                      <p class="font-medium text-primary">Horario de oficina</p>
                      <p class="text-text-muted">Lunes a Viernes: 8:00 — 18:00</p>
                      <p class="text-text-muted">Urgencias: 24h / 365 días</p>
                    </div>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-accent text-lg flex-shrink-0 mt-0.5" aria-hidden="true">domain</span>
                    <div>
                      <p class="font-medium text-primary">Mimtel Soluciones Globales S.L.</p>
                      <p class="text-text-muted">CIF: B87897302</p>
                    </div>
                  </li>
                </ul>
              </div>

              <!-- Quick actions -->
              <div class="flex flex-col gap-3">
                <a href="tel:912000002" class="flex items-center justify-center gap-2 bg-primary text-white rounded-xl py-3.5 px-5 font-heading font-semibold text-sm hover:bg-primary-light transition-colors">
                  <span class="material-symbols-outlined text-lg" aria-hidden="true">call</span>
                  Llamar al 912 000 002
                </a>
                <a href="https://wa.me/34912000002" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 bg-[#25D366] text-white rounded-xl py-3.5 px-5 font-heading font-semibold text-sm hover:bg-[#1fba59] transition-colors">
                  <Image src={whatsappIcon} alt="" width={20} height={20} />
                  WhatsApp Directo
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        TRUST SIGNALS — Stats bar
    ═══════════════════════════════════════════ */}
    <section class="relative py-16 bg-surface overflow-hidden">
      <div class="absolute inset-0 v2-dot-pattern opacity-30" aria-hidden="true"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 v2-reveal">
          <span class="v2-section-label">¿Por qué elegirnos?</span>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mt-3">
            Más de <span class="v2-gradient-text">20 años</span> resolviendo
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 v2-stagger">
          {trustSignals.map(s => (
            <div class="v2-card-glow p-6 text-center group cursor-default">
              <div class="w-14 h-14 mx-auto bg-accent/10 group-hover:bg-accent/20 rounded-2xl flex items-center justify-center mb-4 transition-colors">
                <span class="material-symbols-outlined text-2xl text-accent group-hover:scale-110 transition-transform" aria-hidden="true">{s.icon}</span>
              </div>
              <div class="font-heading font-bold text-primary text-2xl mb-1">{s.value}</div>
              <div class="text-sm text-text-muted">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    {/* ═══════════════════════════════════════════
        COVERAGE AREA — Service area
    ═══════════════════════════════════════════ */}
    <section class="relative py-16 md:py-24 bg-white overflow-hidden">
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="v2-reveal-left">
            <span class="v2-section-label">Zona de Cobertura</span>
            <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mt-3 mb-6 leading-tight">
              Servicios en toda la <span class="v2-gradient-text-blue">Comunidad de Madrid</span>
            </h2>
            <p class="text-lg text-text-muted leading-relaxed mb-8">
              Cubrimos toda la Comunidad de Madrid con atención prioritaria en el corredor sur: Alcorcón, Móstoles, Leganés, Getafe, Fuenlabrada, Parla y alrededores.
            </p>
            <div class="grid grid-cols-2 gap-3">
              {["Alcorcón", "Móstoles", "Leganés", "Getafe", "Fuenlabrada", "Parla", "Madrid Capital", "Toda la CAM"].map(city => (
                <div class="flex items-center gap-2 text-sm">
                  <span class="material-symbols-outlined text-success text-base" aria-hidden="true">check_circle</span>
                  <span class="text-text">{city}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="v2-reveal-right">
            <div class="bg-surface rounded-2xl p-8 border border-border">
              <div class="text-center mb-6">
                <span class="material-symbols-outlined text-5xl text-accent mb-3" aria-hidden="true">map</span>
                <h3 class="font-heading font-bold text-primary text-xl">Cobertura Total</h3>
                <p class="text-text-muted text-sm mt-1">Comunidad de Madrid y alrededores</p>
              </div>
              <div class="space-y-4">
                <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-border">
                  <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-cta" aria-hidden="true">bolt</span>
                    <span class="text-sm font-medium text-primary">Urgencias 24h</span>
                  </div>
                  <span class="text-xs bg-cta/10 text-cta font-heading font-semibold px-3 py-1 rounded-full">Disponible</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-border">
                  <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent" aria-hidden="true">local_shipping</span>
                    <span class="text-sm font-medium text-primary">Desplazamiento</span>
