---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import SolarHighlight from '../components/SolarHighlight.astro';
import WhyUs from '../components/WhyUs.astro';
import Process from '../components/Process.astro';
import Testimonials from '../components/Testimonials.astro';
import PropertyManagers from '../components/PropertyManagers.astro';
import CtaBanner from '../components/CtaBanner.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
---

<Layout title="MIM SISTEMAS | Soluciones Integrales para tu Comunidad y Empresa" description="Instalación, reparación y mantenimiento multitécnico para comunidades de propietarios y empresas en Madrid. Más de 20 años de experiencia. Presupuesto gratis.">
  <Header />
  <main id="main-content">
    <Hero />
    <TrustBar />
    <Services />
    <SolarHighlight />
    <WhyUs />
    <Process />
    <Testimonials />
    <PropertyManagers />
    <CtaBanner />
    <FAQSection />
  </main>
  <Footer />
  <FloatingWhatsApp />
  <MobileCallBar />
</Layout>
